<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_plan_list_inline" model="ir.ui.view">
        <field name="name">partner.plan.list.inline</field>
        <field name="model">partner.plan</field>
        <field name="arch" type="xml">
            <list string="Planes contratados" decoration-success="state == 'active'" decoration-warning="state == 'suspended'" decoration-muted="state == 'cancelled'" editable="bottom">
                <field name="codigo_cliente" placeholder="CF-001"/>
                <field name="plan_id" options="{'no_create': True}"/>
                <field name="plan_type" widget="badge" decoration-success="plan_type == 'fiber'" decoration-info="plan_type == 'wireless'" decoration-warning="plan_type == 'cable'"/>
                <field name="plan_price" string="Bs/mes"/>
                <field name="date_start"/>
                <field name="date_end" optional="show"/>
                <field name="zona" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-warning="state == 'suspended'" decoration-danger="state == 'cancelled'"/>
                <button name="action_suspend" type="object" string="Suspender" icon="fa-pause" class="btn-sm btn-warning" invisible="state != 'active'" confirm="¿Suspender este plan?"/>
                <button name="action_reactivate" type="object" string="Reactivar" icon="fa-play" class="btn-sm btn-success" invisible="state == 'active'" confirm="¿Reactivar este plan?"/>
                <button name="action_cancel" type="object" string="Dar de baja" icon="fa-times" class="btn-sm btn-danger" invisible="state == 'cancelled'" confirm="¿Dar de baja este plan?"/>
            </list>
        </field>
    </record>

    <record id="view_partner_plan_form" model="ir.ui.view">
        <field name="name">partner.plan.form</field>
        <field name="model">partner.plan</field>
        <field name="arch" type="xml">
            <form string="Plan Contratado">
                <header>
                    <button name="action_suspend" type="object" string="Suspender" class="btn-warning" invisible="state != 'active'" confirm="¿Suspender este plan?"/>
                    <button name="action_reactivate" type="object" string="Reactivar" class="btn-success" invisible="state == 'active'" confirm="¿Reactivar este plan?"/>
                    <button name="action_cancel" type="object" string="Dar de baja" class="btn-danger" invisible="state == 'cancelled'" confirm="¿Confirmar baja de este plan?"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,suspended,cancelled"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Suspendido" bg_color="text-bg-warning" invisible="state != 'suspended'"/>
                    <widget name="web_ribbon" title="Dado de baja" bg_color="text-bg-danger" invisible="state != 'cancelled'"/>
                    <div class="oe_title">
                        <label for="codigo_cliente" string="Código de cliente"/>
                        <h1>
                            <field name="codigo_cliente" placeholder="CF-001"/>
                        </h1>
                    </div>
                    <group col="2">
                        <group string="Plan">
                            <field name="partner_id" readonly="1"/>
                            <field name="plan_id"/>
                            <field name="plan_price" readonly="1"/>
                        </group>
                        <group string="Vigencia">
                            <field name="date_start"/>
                            <field name="date_end" readonly="1"/>
                            <field name="lead_id"/>
                        </group>
                    </group>
                    <group string="Datos de Instalación">
                        <group>
                            <field name="zona" placeholder="Ej. Zona Sur"/>
                            <field name="direccion" placeholder="Dirección exacta"/>
                        </group>
                        <group>
                            <field name="ubicacion" widget="url" placeholder="Enlace Google Maps"/>
                        </group>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1" placeholder="Observaciones adicionales..."/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_partner_form_ext_clean" model="ir.ui.view">
        <field name="name">res.partner.form.ext.clean</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="customer_contract.view_partner_form_contract_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='function']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='vat']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='website']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='category_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='lang']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='street2']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='city']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[.//field[@name='street']]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='state_id']" position="replace"/>
            <xpath expr="//field[@name='zip']" position="replace"/>
            <xpath expr="//field[@name='country_id']" position="replace"/>
            <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="string">Celular</attribute>
                <attribute name="placeholder">Celular</attribute>
            </xpath>
            <xpath expr="//group[.//field[@name='street']]" position="before">
                <group col="2">
                    <field name="celular" string="Teléfono" placeholder="Teléfono" invisible="is_company"/>
                    <field name="ci" string="CI" placeholder="CI" invisible="company_type != 'person'"/>
                </group>
                <group string="Dirección" col="2" invisible="is_company">
                    <field name="zona_id" string="Zona?" placeholder="Seleccionar o crear zona" context="{'form_view_ref': 'wigo_ftth.view_wigo_zone_form'}"/>
                    <field name="direccion" string="Dirección?" placeholder="Dirección exacta"/>
                    <field name="ubicacion" string="Ubicación?" widget="url" placeholder="Pegar enlace de Google Maps aquí"/>
                    <field name="coordenadas" string="Coordenadas?" placeholder="Ej. -17.783327, -63.182140"/>
                </group>
            </xpath>
            <xpath expr="//notebook/page[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//notebook/page[2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//notebook/page[3]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_plans" type="object" class="oe_stat_button" icon="fa-wifi" invisible="total_plan_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="active_plan_count"/>
                        </span>
                        <span class="o_stat_text">Planes activos</span>
                    </div>
                </button>
                <button name="action_view_helpdesk_tickets" type="object" class="oe_stat_button" icon="fa-ticket" invisible="helpdesk_ticket_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="helpdesk_ticket_open_count"/>
                        </span>
                        <span class="o_stat_text">Tickets abiertos</span>
                    </div>
                </button>
                <button name="action_view_referrals" type="object" class="oe_stat_button" icon="fa-users" invisible="is_company">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="referral_count"/>
                        </span>
                        <span class="o_stat_text">Referidos</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Notas" name="wigo_partner_notes">
                    <field name="notes" nolabel="1" placeholder="Agregar notas internas sobre este cliente..."/>
                </page>
                <page string="Tickets" name="wigo_partner_tickets">
                    <field name="all_helpdesk_ticket_ids" readonly="1" invisible="helpdesk_ticket_count == 0">
                        <list string="Tickets de Soporte" decoration-success="is_closed" decoration-danger="not is_closed">
                            <field name="name" string="Ticket"/>
                            <field name="title" string="Descripción"/>
                            <field name="priority" widget="priority"/>
                            <field name="stage_id" widget="badge"/>
                            <field name="is_closed" invisible="1"/>
                            <field name="create_date" string="Creado el"/>
                            <field name="date_closed" string="Cerrado el" optional="show"/>
                        </list>
                    </field>
                </page>
                <page string="Referidos" name="wigo_referrals" invisible="company_type == 'company'">
                    <field name="referral_as_referred_ids" readonly="1" invisible="not referral_as_referred_ids">
                        <list string="Fui recomendado por">
                            <field name="referrer_id" string="Me recomendó"/>
                            <field name="promo_id" string="Promoción"/>
                            <field name="date" string="Fecha"/>
                            <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-info="state == 'valid'" decoration-success="state == 'rewarded'" decoration-danger="state == 'cancelled'"/>
                        </list>
                    </field>
                    <div class="alert alert-info mb-3" role="status" invisible="not referral_as_referred_ids">
                        <i class="fa fa-info-circle"/>
 Fuiste recomendado por un cliente. Este registro es solo informativo y no suma al contador de referidos.
                    </div>
                    <div class="o_horizontal_separator mt-2 mb-2" invisible="not referral_as_referred_ids">Clientes que yo recomendé</div>
                    <field name="referral_as_referrer_ids" readonly="1">
                        <list string="Clientes que recomendé" decoration-success="state == 'rewarded'" decoration-info="state == 'valid'" decoration-warning="state == 'pending'" decoration-muted="state == 'cancelled'">
                            <field name="referred_id" string="Cliente referido"/>
                            <field name="promo_id" string="Promoción"/>
                            <field name="date" string="Fecha"/>
                            <field name="validation_date" string="Validado el" optional="show"/>
                            <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-info="state == 'valid'" decoration-primary="state == 'ready_for_reward'" decoration-success="state == 'rewarded'" decoration-danger="state == 'cancelled'"/>
                        </list>
                    </field>
                    <div class="mt-2 text-muted small" invisible="referral_count == 0">
                        Total referidos activos: <strong>
                        <field name="referral_count" readonly="1"/>
                    </strong>
                </div>
                <div class="mt-2 text-muted small" invisible="referral_count != 0">
                        Aún no has recomendado a ningún cliente. Los referidos se registran en <b>Promociones Referidos</b>.
                </div>
            </page>
        </xpath>
        <xpath expr="//page[@name='wigo_contratos_cc']" position="before">
            <xpath expr="//page[@name='wigo_partner_notes']" position="move"/>
        </xpath>
        <xpath expr="//page[@name='wigo_partner_notes']" position="after">
            <xpath expr="//page[@name='wigo_contratos_cc']" position="move"/>
        </xpath>
        <xpath expr="//page[@name='wigo_contratos_cc']" position="after">
            <xpath expr="//page[@name='wigo_partner_tickets']" position="move"/>
        </xpath>
        <xpath expr="//page[@name='wigo_partner_tickets']" position="after">
            <xpath expr="//page[@name='wigo_referrals']" position="move"/>
        </xpath>
    </field>
</record>

<record id="res_partner_search_filters_custom" model="ir.ui.view">
    <field name="name">res.partner.search.filters.custom</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_res_partner_filter"/>
    <field name="arch" type="xml">
        <xpath expr="//search" position="inside">
            <field name="partner_plan_ids" string="Código CF" filter_domain="[('partner_plan_ids.codigo_cliente','ilike',self)]"/>
            <filter string="Clientes (no empleados)" name="non_employees" domain="[('employee','=',False), ('is_employee','=',False)]"/>
            <filter string="Con contratos" name="with_contracts" domain="[('contract_ids','!=',False)]"/>
            <filter string="Con plan activo" name="with_active_plan" domain="[('partner_plan_ids.state','=','active')]"/>
            <filter string="Ha referido" name="has_referrals" domain="[('referral_as_referrer_ids','!=',False)]"/>
            <filter string="Fue referido" name="was_referred" domain="[('referral_as_referred_ids','!=',False)]"/>
            <filter string="Empleados" name="employees" domain="[('is_employee','=',True)]"/>
            <filter string="Con oportunidades" name="with_leads" domain="[('lead_ids','!=',False)]"/>
        </xpath>
    </field>
</record>

<record id="contacts.action_contacts" model="ir.actions.act_window">
    <field name="context">{'default_is_company': True, 'search_default_non_employees': 1}</field>
</record>
</odoo>
