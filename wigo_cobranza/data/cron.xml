<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Cron diario: evaluar estados de cobranza según reglas -->
    <record id="cron_evaluar_cobranza" model="ir.cron">
        <field name="name">Wigo Cobranza: Evaluar estados de cobranza (diario)</field>
        <field name="model_id" ref="model_wigo_pago_estado"/>
        <field name="state">code</field>
        <field name="code">model.cron_evaluar_cobranza()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="nextcall">2026-05-04 06:00:00</field>
    </record>

    <!-- Cron día 1 de cada mes: crear registros pendientes según reglas + alerta cobro -->
    <record id="cron_alertar_mora_dia1" model="ir.cron">
        <field name="name">Wigo Cobranza: Generar cobros pendientes según reglas (dia 1)</field>
        <field name="model_id" ref="model_wigo_pago_estado"/>
        <field name="state">code</field>
        <field name="code">model.cron_alertar_mora_dia1()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="nextcall">2026-05-01 07:00:00</field>
    </record>

    <!-- Cron día 1 de cada mes: detectar mora según reglas y alertar suspension -->
    <record id="cron_alertar_suspension" model="ir.cron">
        <field name="name">Wigo Cobranza: Detectar mora y alertar suspension (dia 1)</field>
        <field name="model_id" ref="model_wigo_pago_estado"/>
        <field name="state">code</field>
        <field name="code">model.cron_alertar_suspension()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="nextcall">2026-05-01 08:00:00</field>
    </record>

    <!-- Cron día 1 de cada mes: detectar clientes incobrables según reglas -->
    <record id="cron_detectar_incobrables" model="ir.cron">
        <field name="name">Wigo Cobranza: Detectar incobrables según reglas (dia 1)</field>
        <field name="model_id" ref="model_wigo_pago_estado"/>
        <field name="state">code</field>
        <field name="code">model.cron_detectar_incobrables()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="nextcall">2026-05-01 09:00:00</field>
    </record>

</odoo>
