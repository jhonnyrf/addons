<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron maestro diario: procesa generación, mora e incobrables con reglas BD -->
        <record id="cron_procesar_cobranza" model="ir.cron">
            <field name="name">Wigo Cobranza: Procesar cobranza automática (diario)</field>
            <field name="model_id" ref="model_wigo_pago_estado"/>
            <field name="state">code</field>
            <field name="code">model.cron_procesar_cobranza()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
