<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_adjustment_type_list" model="ir.ui.view">
        <field name="name">wigo.cobranza.tipo_ajuste.list</field>
        <field name="model">wigo.cobranza.tipo_ajuste</field>
        <field name="arch" type="xml">
            <list string="Tipos de ajuste" default_order="is_default desc, name asc">
                <field name="name"/>
                <field name="is_default" widget="boolean_toggle"/>
                <field name="requires_reason" widget="boolean_toggle"/>
                <field name="enable_proration" widget="boolean_toggle"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="color" widget="color_picker" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_adjustment_type_form" model="ir.ui.view">
        <field name="name">wigo.cobranza.tipo_ajuste.form</field>
        <field name="model">wigo.cobranza.tipo_ajuste</field>
        <field name="arch" type="xml">
            <form string="Tipo de ajuste">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active" widget="boolean_toggle"/>
                        <field name="is_default" widget="boolean_toggle"/>
                        <field name="color" widget="color_picker"/>
                        <field name="requires_reason" widget="boolean_toggle"/>
                        <field name="enable_proration" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_adjustment_type_search" model="ir.ui.view">
        <field name="name">wigo.cobranza.tipo_ajuste.search</field>
        <field name="model">wigo.cobranza.tipo_ajuste</field>
        <field name="arch" type="xml">
            <search string="Buscar tipos de ajuste">
                <field name="name"/>
                <filter name="default_only" string="Por defecto" domain="[('is_default', '=', True)]"/>
                <filter name="proration_enabled" string="Con prorrateo" domain="[('enable_proration', '=', True)]"/>
                <filter name="reason_required" string="Requiere motivo" domain="[('requires_reason', '=', True)]"/>
                <separator/>
                <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactivos" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_adjustment_type" model="ir.actions.act_window">
        <field name="name">Tipos de ajuste</field>
        <field name="res_model">wigo.cobranza.tipo_ajuste</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_adjustment_type_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay tipos de ajuste registrados aún. Crea algunos para clasificar los ajustes aplicados a los contratos.
            </p>
        </field>
    </record>

</odoo>
