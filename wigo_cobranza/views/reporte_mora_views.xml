<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         REPORTE: Estado de mora diario (pivot + list)
    ══════════════════════════════════════════════════════════ -->
    <record id="view_reporte_mora_pivot" model="ir.ui.view">
        <field name="name">wigo.pago.estado.pivot.mora</field>
        <field name="model">wigo.pago.estado</field>
        <field name="arch" type="xml">
            <pivot string="Reporte de Mora" disable_linking="False">
                <field name="estado_pago" type="row"/>
                <field name="plan_id" type="col"/>
                <field name="monto_a_cobrar" type="measure" string="A cobrar (Bs)"/>
                <field name="monto_pagado" type="measure" string="Pagado (Bs)"/>
            </pivot>
        </field>
    </record>

    <record id="view_reporte_mora_graph" model="ir.ui.view">
        <field name="name">wigo.pago.estado.graph.mora</field>
        <field name="model">wigo.pago.estado</field>
        <field name="arch" type="xml">
            <graph string="Distribución de Cobros" type="bar">
                <field name="estado_pago" type="row"/>
                <field name="monto_a_cobrar" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         REPORTE: Altas / Bajas / Cambios semanales
         Usa directamente wigo.ftth.client.service con filtros
    ══════════════════════════════════════════════════════════ -->
    <record id="view_reporte_altas_bajas_search" model="ir.ui.view">
        <field name="name">wigo.ftth.client.service.search.cobranza</field>
        <field name="model">wigo.ftth.client.service</field>
        <field name="arch" type="xml">
            <search string="Reporte Altas / Bajas">
                <field name="codigo_cliente" string="Código CF"/>
                <field name="partner_id" string="Cliente"/>
                <field name="plan_id" string="Plan"/>
                <separator/>
                <filter name="altas_semana" string="Altas esta semana" domain="[ ('estado_servicio','=','active'), ('fecha_instalacion','&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d'))
                        ]"/>
                <filter name="bajas_semana" string="Bajas esta semana" domain="[ ('estado_servicio','=','baja'), ('fecha_baja','&gt;=', (context_today() - relativedelta(days=7)).strftime('%Y-%m-%d'))
                        ]"/>
                <filter name="altas_mes" string="Altas este mes" domain="[ ('estado_servicio','=','active'), ('fecha_instalacion','&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d'))
                        ]"/>
                <filter name="bajas_mes" string="Bajas este mes" domain="[ ('estado_servicio','=','baja'), ('fecha_baja','&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d'))
                        ]"/>
                <filter name="suspendidos" string="Suspendidos actualmente" domain="[('estado_servicio','=','suspended')]"/>
                <separator/>
                <filter name="group_estado" string="Agrupar por Estado del servicio" context="{'group_by':'estado_servicio'}"/>
                <filter name="group_plan" string="Agrupar por Plan" context="{'group_by':'plan_id'}"/>
                <filter name="group_mes_instalacion" string="Agrupar por Mes de instalación" context="{'group_by':'fecha_instalacion:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_reporte_altas_bajas" model="ir.actions.act_window">
        <field name="name">Altas / Bajas / Cambios de Plan</field>
        <field name="res_model">wigo.ftth.client.service</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_reporte_altas_bajas_search"/>
        <field name="context">{'search_default_altas_mes': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay altas o bajas en el período seleccionado.
            </p>
        </field>
    </record>

    <!-- Acción para reporte de mora (pivot + list) -->
    <record id="action_reporte_mora" model="ir.actions.act_window">
        <field name="name">Estado de Mora</field>
        <field name="res_model">wigo.pago.estado</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="wigo_cobranza.view_pago_estado_search"/>
        <field name="context">{'search_default_mora': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay clientes en mora. ¡Excelente!
            </p>
        </field>
    </record>

</odoo>
