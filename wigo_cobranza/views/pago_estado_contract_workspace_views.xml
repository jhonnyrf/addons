<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pago_estado_contract_list_new" model="ir.ui.view">
        <field name="name">wigo.pago.estado.contract.workspace.list</field>
        <field name="model">wigo.pago.estado</field>
        <field name="arch" type="xml">
            <list string="Pagos mensuales por contrato" create="true" default_order="anio desc, mes desc" decoration-success="estado_pago == 'pagado'" decoration-warning="estado_pago == 'pendiente'" decoration-danger="estado_pago == 'mora'">
                <field name="periodo"/>
                <field name="payment_mode" string="Modalidad" optional="show"/>
                <field name="monto_a_cobrar" />
                <field name="monto_pagado" />
                <field name="diferencia" />
                <field name="fecha_pago"/>
                <field name="estado_pago" widget="badge"/>
                <field name="canal_pago" optional="show"/>
                <field name="registrado_por" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_pago_estado_contract_form_new" model="ir.ui.view">
        <field name="name">wigo.pago.estado.contract.workspace.form</field>
        <field name="model">wigo.pago.estado</field>
        <field name="arch" type="xml">
            <form string="Registro mensual de pago">
                <header>
                    <button name="action_registrar_pago" string="Confirmar Pago" type="object" class="btn-primary" invisible="estado_pago == 'pagado'"/>
                    <button name="action_marcar_mora" string="Marcar en Mora" type="object" class="btn-warning" invisible="estado_pago in ['pagado', 'al_dia', 'mora']"/>
                    <button name="action_editar_valores_contables" string="Editar valores contables" type="object" class="btn-secondary" invisible="estado_pago != 'pagado'"/>

                    <!-- Ver Recibo: solo visible cuando ya se generó el recibo -->
                    <button name="action_abrir_recibo" string="Ver Recibo" type="object" class="btn-secondary" invisible="estado_pago != 'pagado' or not recibo_generado"/>

                    <!-- Generar Recibo: solo visible cuando NO existe aún -->
                    <button name="action_generar_recibo" string="Generar Recibo" type="object" class="btn-secondary" invisible="estado_pago != 'pagado' or recibo_generado"/>

                    <!-- Imprimir Recibo: solo visible cuando ya se generó -->
                    <button name="action_imprimir_recibo" string="Imprimir Recibo" type="object" class="btn-secondary" invisible="estado_pago != 'pagado' or not recibo_generado"/>

                    <button name="action_registrar_factura" string="Registrar Factura" type="object" class="btn-secondary" invisible="estado_pago != 'pagado'"/>
                    <field name="estado_pago" widget="statusbar" statusbar_visible="pendiente,pagado,mora"/>
                    <!-- Campos necesarios para condiciones invisible -->
                    <field name="recibo_generado" invisible="1"/>
                    <field name="recibo_id" invisible="1"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="En mora" bg_color="text-bg-danger" invisible="estado_pago != 'mora'"/>
                    <widget name="web_ribbon" title="Pagado" bg_color="text-bg-success" invisible="estado_pago != 'pagado'"/>
                    <widget name="web_ribbon" title="Edición contable" bg_color="text-bg-warning" invisible="not contabilidad_editable"/>

                    <group string="Contrato y periodo" col="2">
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="contract_id" readonly="1"/>
                            <field name="plan_id" readonly="1"/>
                            <field name="mes"/>
                            <field name="anio"/>
                            <field name="periodo" readonly="1"/>
                        </group>
                        <group>
                            <field name="monto_plan" readonly="1"/>
                            <field name="payment_mode" readonly="1"/>
                            <field name="es_primer_mes"/>
                            <field name="monto_prorrateo" readonly="not es_primer_mes"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Pago y Control">
                            <group string="Contabilidad" col="2">
                                <group>
                                    <field name="contabilidad_editable" invisible="1"/>
                                    <field name="monto_a_cobrar" readonly="estado_pago in ['pagado', 'al_dia'] and not contabilidad_editable"/>
                                    <field name="monto_pagado" readonly="estado_pago in ['pagado', 'al_dia'] and not contabilidad_editable"/>
                                    <field name="diferencia" readonly="1"/>
                                </group>
                                <group>
                                    <field name="fecha_pago" widget="date" options="{'numeric': true}"/>
                                    <field name="canal_pago" string="Canal de pago" options="{'no_open': True}"/>
                                    <field name="registrado_por" readonly="1"/>
                                    <field name="justificacion_edicion" placeholder="Justificación obligatoria cuando se editen montos contables fuera de pendiente." invisible="not contabilidad_editable" required="contabilidad_editable"/>
                                </group>
                            </group>
                        </page>

                        <page string="Comprobante" name="comprobante">
                            <field name="comprobante_adjunto_is_image" invisible="1"/>
                            <field name="comprobante_adjunto_is_pdf" invisible="1"/>
                            <field name="has_comprobante" invisible="1"/>

                            <group string="Adjunto de respaldo" col="2">
                                <group>
                                    <field name="comprobante_adjunto" invisible="1"/>
                                    <field name="comprobante_adjunto_fname" invisible="1"/>
                                    <field name="comprobante_attachment_ids" widget="many2many_binary" string="Archivo(s) de comprobante" options="{'accepted_file_extensions': '.pdf,.jpg,.jpeg,.png'}"/>
                                </group>
                                <group invisible="not has_comprobante">
                                    <div class="d-flex gap-2 flex-wrap" style="margin-bottom: 12px;">
                                        <button name="action_ver_comprobante" type="object" string="Ver en grande" class="btn btn-outline-primary"/>
                                        <button name="action_descargar_comprobante" type="object" string="Descargar" class="btn btn-primary"/>
                                    </div>
                                </group>
                                <div role="alert" class="alert alert-info mb-3" invisible="has_comprobante" style="margin: 8px 0; width: 100%; display: flex; align-items: center; gap: 12px;">
                                    <i class="fa fa-info-circle me-1" title="Información"/>
                                    Formatos aceptados: <strong>JPG, PNG, PDF</strong>.
                                </div>
                            </group>

                            <group string="Vista previa" invisible="not comprobante_adjunto_is_image">
                                <field name="comprobante_adjunto" widget="image" nolabel="1" readonly="1" options="{'size': [900, 600]}" class="o_field_image_full"/>
                            </group>

                            <group string="Documento PDF" invisible="not comprobante_adjunto_is_pdf">
                                <div role="status" class="alert alert-success" style="width: 100%; margin: 8px 0; display: flex; align-items: center; gap: 12px;">
                                    <i class="fa fa-file-pdf-o fa-2x text-danger" title="Archivo PDF"/>
                                    <div>
                                        <strong>Archivo PDF cargado correctamente.</strong>
                                        <br/>
                                        Usa los botones para ver en grande o descargar.
                                    </div>
                                </div>
                            </group>
                        </page>
                    </notebook>

                    <field name="notas" placeholder="Observaciones de cobranza para este mes..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

</odoo>
