<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_recibo_config_form" model="ir.ui.view">
        <field name="name">wigo.recibo.config.form</field>
        <field name="model">wigo.recibo.config</field>
        <field name="arch" type="xml">
            <form string="Configuración del Recibo">
                <header>
                    <button name="action_reset_defaults" string="↺ Restaurar diseño por defecto"
                            type="object" class="btn-secondary"
                            confirm="¿Restaurar todos los valores de diseño a los predeterminados?"/>
                </header>
                <sheet style="max-width: none;">
                    <div class="oe_title">
                        <h1>⚙️ Configuración del Recibo de Cobro</h1>
                        <p class="text-muted">
                            Personaliza todos los aspectos visuales del recibo. Los cambios se
                            aplican inmediatamente al siguiente recibo sin reiniciar el servidor.
                        </p>
                    </div>

                    <!-- ══════ LAYOUT: OPCIONES + PREVIEW ══════ -->
                    <div class="row g-0">

                        <!-- COLUMNA IZQUIERDA: todos los controles -->
                        <div class="col-xl-6 pe-3">

                            <!-- ─ Datos de empresa ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">🏢 Datos de la Empresa</div>
                                <div class="card-body">
                                    <group col="2">
                                        <group>
                                            <field name="empresa_nombre"/>
                                            <field name="empresa_direccion"/>
                                            <field name="empresa_ciudad"/>
                                            <field name="empresa_celular"/>
                                        </group>
                                        <group>
                                            <field name="empresa_email" placeholder="info@wigo.com"/>
                                            <field name="empresa_nit" placeholder="1234567890"/>
                                            <field name="empresa_slogan" placeholder="Tu internet veloz y confiable"/>
                                        </group>
                                    </group>
                                </div>
                            </div>

                            <!-- ─ Logo ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">🖼️ Logo</div>
                                <div class="card-body">
                                    <group col="2">
                                        <group>
                                            <field name="logo" widget="image"
                                                   options="{'size': [350, 140]}"
                                                   string="Logo del recibo"/>
                                            <field name="usar_logo_imagen"/>
                                        </group>
                                        <group>
                                            <field name="logo_ancho"
                                                   widget="integer"
                                                   string="Ancho máximo (px)"/>
                                            <field name="layout_logo"/>
                                        </group>
                                    </group>
                                </div>
                            </div>

                            <!-- ─ Firma ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">✍️ Datos de la Firma</div>
                                <div class="card-body">
                                    <group col="2">
                                        <field name="firma_nombre"/>
                                        <field name="firma_cargo"/>
                                        <field name="firma_celular"/>
                                    </group>
                                </div>
                            </div>

                            <!-- ─ Pie de página ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">📄 Pie de Página</div>
                                <div class="card-body">
                                    <group col="2">
                                        <field name="mostrar_pie"/>
                                        <field name="texto_pie"
                                               placeholder="Gracias por su pago puntual."
                                               invisible="not mostrar_pie"/>
                                    </group>
                                </div>
                            </div>

                            <!-- ─ Colores ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">🎨 Colores</div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-6">
                                            <group string="Encabezado">
                                                <field name="color_primario" widget="color"/>
                                                <field name="color_secundario" widget="color"/>
                                                <field name="color_texto_header" widget="color"/>
                                            </group>
                                        </div>
                                        <div class="col-6">
                                            <group string="Cuerpo">
                                                <field name="color_fondo_recibo" widget="color"/>
                                                <field name="color_texto_principal" widget="color"/>
                                                <field name="color_texto_secundario" widget="color"/>
                                                <field name="color_borde" widget="color"/>
                                                <field name="color_fondo_monto" widget="color"/>
                                            </group>
                                        </div>
                                    </div>
                                    <div class="alert alert-info mt-2 mb-0" style="font-size:12px;">
                                        <i class="fa fa-info-circle me-1"/>
                                        Los colores se actualizan en la vista previa al guardar.
                                        Formato HEX recomendado (ej: <code>#cc0000</code>).
                                    </div>
                                </div>
                            </div>

                            <!-- ─ Tipografía ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">🔤 Tipografía</div>
                                <div class="card-body">
                                    <group col="2">
                                        <group>
                                            <field name="fuente_familia"/>
                                            <field name="fuente_titulo_negrita"/>
                                        </group>
                                        <group>
                                            <field name="tamano_fuente_base"/>
                                            <field name="tamano_titulo"/>
                                            <field name="tamano_empresa"/>
                                        </group>
                                    </group>
                                </div>
                            </div>

                            <!-- ─ Layout ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">📐 Layout y Estructura</div>
                                <div class="card-body">
                                    <group col="2">
                                        <group>
                                            <field name="estilo_header"/>
                                            <field name="border_radius"/>
                                            <field name="mostrar_numero_grande"/>
                                        </group>
                                        <group>
                                            <field name="mostrar_banda_decorativa"/>
                                            <field name="ancho_banda"
                                                   invisible="not mostrar_banda_decorativa"/>
                                        </group>
                                    </group>
                                </div>
                            </div>

                            <!-- ─ Tabla ─ -->
                            <div class="card mb-3">
                                <div class="card-header fw-bold">📋 Tabla de Detalle</div>
                                <div class="card-body">
                                    <group col="2">
                                        <field name="tabla_header_texto"/>
                                        <field name="tabla_monto_texto"/>
                                        <field name="mostrar_columna_codigo"/>
                                    </group>
                                </div>
                            </div>

                        </div><!-- /col-xl-6 -->

                        <!-- COLUMNA DERECHA: preview REACTIVO (OWL widget) -->
                        <div class="col-xl-6 ps-3">
                            <div style="position: sticky; top: 70px;">
                                <div class="card">
                                    <div class="card-header fw-bold d-flex justify-content-between align-items-center"
                                         style="background: linear-gradient(135deg, #1e3a5f, #2d5a9e); color: white;">
                                        <span><i class="fa fa-eye me-2"/>Vista Previa en Tiempo Real</span>
                                        <small style="opacity:0.8;">Se actualiza al instante</small>
                                    </div>
                                    <div class="card-body p-2" style="background:#f3f4f6;max-height:80vh;overflow-y:auto;">
                                        <widget name="recibo_config_preview"/>
                                    </div>
                                </div>
                                <div class="text-muted mt-2" style="font-size:11px;text-align:center;">
                                    <i class="fa fa-check-circle me-1 text-success"/>
                                    Los cambios se reflejan en la vista previa sin necesidad de guardar.
                                </div>
                            </div>
                        </div>

                                        </div><!-- /row -->

                </sheet>
            </form>
        </field>
    </record>

    <!-- Server action para abrir el singleton -->
    <record id="action_recibo_config" model="ir.actions.server">
        <field name="name">Configuración del Recibo</field>
        <field name="model_id" ref="model_wigo_recibo_config"/>
        <field name="state">code</field>
        <field name="code">
config = env['wigo.recibo.config'].get_config()
action = {
    'type': 'ir.actions.act_window',
    'name': 'Configuración del Recibo',
    'res_model': 'wigo.recibo.config',
    'view_mode': 'form',
    'res_id': config.id,
    'target': 'current',
}
        </field>
    </record>

</odoo>
