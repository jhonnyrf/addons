<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_partner_cobranza_list" model="ir.ui.view">
        <field name="name">res.partner.cobranza.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Clientes con contrato" default_order="name asc" decoration-success="active_contract_count &gt; 0" create="false">
                <field name="name" string="Cliente"/>
                <field name="cobranza_ci" optional="show"/>
                <field name="cobranza_celular" optional="show"/>
                <field name="cobranza_zona" optional="show"/>
                <field name="phone" optional="show"/>
                <field name="email" optional="show"/>
                <field name="active_contract_count" string="Contratos activos"/>
                <field name="contract_any_count" string="Total contratos" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_partner_cobranza_kanban" model="ir.ui.view">
        <field name="name">res.partner.cobranza.kanban</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <kanban create="false" sample="1" quick_create="false">
                <field name="name"/>
                <field name="cobranza_ci"/>
                <field name="cobranza_celular"/>
                <field name="cobranza_zona"/>
                <field name="active_contract_count"/>
                <field name="contract_any_count"/>
                <field name="email"/>
                <field name="phone"/>
                <templates>
                    <t t-name="card">
                        <aside>
                            <div style="width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,#1e3a5f,#2d5a9e);color:white;display:flex;align-items:center;justify-content:center;font-weight:bold;font-size:16px;">
                                <t t-esc="record.name.value ? record.name.value[0].toUpperCase() : '?'"/>
                            </div>
                        </aside>
                        <main>
                            <div class="d-flex justify-content-between align-items-start mb-1">
                                <strong style="font-size:14px;">
                                    <field name="name"/>
                                </strong>
                                <span t-attf-class="badge #{record.active_contract_count.value > 0 ? 'text-bg-success' : 'text-bg-secondary'}" style="white-space:nowrap;font-size:11px;">
                                    <i class="fa fa-file-text-o me-1"/>
                                    <t t-esc="record.active_contract_count.value"/>
activo(s)
                                </span>
                            </div>
                            <div style="font-size:11px;color:#6b7280;margin-top:4px;">
                                <t t-if="record.cobranza_ci.value">
                                    <div>
                                        <i class="fa fa-id-card me-1"/>
CI: <field name="cobranza_ci"/>
                                    </div>
                                </t>
                                <t t-if="record.cobranza_celular.value">
                                    <div>
                                        <i class="fa fa-phone me-1"/>
Cel: <field name="cobranza_celular"/>
                                    </div>
                                </t>
                                <t t-if="record.cobranza_zona.value">
                                    <div>
                                        <i class="fa fa-map-marker me-1"/>
Zona: <field name="cobranza_zona"/>
                                    </div>
                                </t>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-2" style="border-top:1px solid #e5e7eb;padding-top:6px;">
                                <span style="font-size:10px;color:#9ca3af;">
                                    Total contratos: <field name="contract_any_count"/>
                                </span>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_partner_cobranza_form" model="ir.ui.view">
        <field name="name">res.partner.cobranza.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Perfil de Cliente - Cobranza" create="false" delete="false">
                <sheet style="width:100%;max-width:none;padding:1.5rem;">
                    <div class="d-flex justify-content-between align-items-center mb-4" style="gap:1rem;">
                        <div class="d-flex align-items-center gap-3">
                            <div>
                                <h1 class="text-primary mb-0" style="font-size:2rem; line-height:1.1;">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                        </div>
                        <button name="action_open_contact_form" type="object" string="Ver más detalles contacto" class="btn-success" icon="fa-external-link"/>
                    </div>
                    <group string="Datos del cliente" col="2">
                        <group>
                            <field name="cobranza_ci" readonly="1" string="Carnet / CI"/>
                            <field name="cobranza_celular" readonly="1" string="Celular"/>
                            <field name="phone" readonly="1"/>
                        </group>
                        <group>
                            <field name="cobranza_zona" readonly="1" string="Zona"/>
                            <field name="cobranza_direccion" readonly="1" string="Dirección"/>
                            <field name="email" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Contratos del cliente"/>
                    <field name="active_contract_ids" nolabel="1" readonly="1" context="{'default_partner_id': id, 'search_default_active': 1}">
                        <list string="Contratos" default_order="contract_date desc" decoration-success="state == 'active'" decoration-warning="state in ['pending','signed']" decoration-danger="state == 'overdue'" decoration-muted="state == 'terminated'">
                            <field name="name" string="Contrato" class="fw-bold"/>
                            <field name="plan_id" string="Plan"/>
                            <field name="payment_mode"/>
                            <field name="plan_price" string="Tarifa (Bs)" widget="monetary"/>
                            <field name="installation_date" string="Inicio"/>
                            <field name="contract_date" string="Contrato" optional="hide"/>
                            <field name="state" widget="badge"/>
                            <button name="action_view_cobranza_mensual" type="object" string="Pagos" class="btn-primary" icon="fa-calendar"/>
                            <button name="action_open_contract_full" type="object" string="Mas detalles" icon="fa-external-link" class="btn-secondary"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_partner_cobranza_search" model="ir.ui.view">
        <field name="name">res.partner.cobranza.search</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Buscar clientes con contrato">
                <field name="name" string="Cliente"/>
                <field name="cobranza_ci" string="CI"/>
                <field name="vat" string="NIT"/>
                <field name="cobranza_celular" string="Celular"/>
                <filter name="has_active_contract" string="Con contrato activo" domain="[('contract_ids.state', '=', 'active'), ('contract_ids.is_superseded', '=', False)]"/>
                <filter name="has_payments" string="Con pagos registrados" domain="[('cobranza_pago_ids', '!=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_cobranza_contract_customers" model="ir.actions.act_window">
        <field name="name">Clientes con Contrato</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'create': False}</field>
        <field name="search_view_id" ref="view_partner_cobranza_search"/>
        <field name="domain">[('contract_ids.state', '=', 'active'), ('contract_ids.is_superseded', '=', False)]</field>
    </record>

    <record id="action_cobranza_contract_customers_kanban" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_cobranza_contract_customers"/>
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_partner_cobranza_kanban"/>
    </record>

    <record id="action_cobranza_contract_customers_list" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_cobranza_contract_customers"/>
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_partner_cobranza_list"/>
    </record>

    <record id="action_cobranza_contract_customers_form" model="ir.actions.act_window.view">
        <field name="act_window_id" ref="action_cobranza_contract_customers"/>
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_partner_cobranza_form"/>
    </record>

</odoo>
