<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         LIST VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_incobrable_list" model="ir.ui.view">
        <field name="name">wigo.incobrable.list</field>
        <field name="model">wigo.incobrable</field>
        <field name="arch" type="xml">
            <list string="Incobrables"
                  decoration-danger="state == 'baja_incobrable'"
                  decoration-success="state == 'recuperado'"
                  decoration-muted="state == 'condonado'">
                <field name="codigo_cliente" optional="show"/>
                <field name="partner_id"/>
                <field name="contract_id" optional="show"/>
                <field name="plan_id" optional="show"/>
                <field name="meses_adeudados"/>
                <field name="monto_total_adeudado" widget="monetary" options="{'currency_field': False}"/>
                <field name="monto_condonado" optional="show" widget="monetary" options="{'currency_field': False}"/>
                <field name="monto_cobrado" optional="show" widget="monetary" options="{'currency_field': False}"/>
                <field name="diferencia_incobrable" widget="monetary" options="{'currency_field': False}"
                       string="Incobrable (Bs)"/>
                <field name="fecha_declaracion"/>
                <field name="equipo_retirado" optional="show"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'baja_incobrable'"
                       decoration-success="state == 'recuperado'"
                       decoration-warning="state == 'activo'"
                       decoration-muted="state == 'condonado'"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         FORM VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_incobrable_form" model="ir.ui.view">
        <field name="name">wigo.incobrable.form</field>
        <field name="model">wigo.incobrable</field>
        <field name="arch" type="xml">
            <form string="Registro Incobrable">
                <header>
                    <button name="action_marcar_baja_incobrable" string="⛔ Baja Incobrable"
                            type="object" class="btn-danger"
                            invisible="state == 'baja_incobrable'"
                            confirm="¿Confirma declarar esta deuda como incobrable y dar de baja el servicio?"/>
                    <button name="action_marcar_recuperado" string="✅ Recuperado"
                            type="object" class="btn-success"
                            invisible="state in ['recuperado','condonado']"/>
                    <button name="action_marcar_condonado" string="📝 Condonar Deuda"
                            type="object" class="btn-warning"
                            invisible="state in ['recuperado','condonado']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="activo,baja_incobrable,recuperado,condonado"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="BAJA INCOBRABLE" bg_color="text-bg-danger"
                            invisible="state != 'baja_incobrable'"/>
                    <widget name="web_ribbon" title="Recuperado" bg_color="text-bg-success"
                            invisible="state != 'recuperado'"/>
                    <widget name="web_ribbon" title="Condonado" bg_color="text-bg-secondary"
                            invisible="state != 'condonado'"/>

                    <div class="oe_title">
                        <label for="partner_id"/>
                        <h1><field name="partner_id"/></h1>
                        <h2><field name="codigo_cliente" readonly="1"/></h2>
                    </div>

                    <group col="2">
                        <group string="Datos del cliente">
                            <field name="contract_id"
                                   domain="[('partner_id','=',partner_id),('state','=','active')]"/>
                            <field name="client_service_id"
                                   domain="[('partner_id','=',partner_id)]"/>
                            <field name="plan_id" readonly="1"/>
                        </group>
                        <group string="Deuda">
                            <field name="meses_adeudados"/>
                            <field name="monto_total_adeudado"
                                   widget="monetary" options="{'currency_field': False}"/>
                            <field name="monto_condonado"
                                   widget="monetary" options="{'currency_field': False}"/>
                            <field name="monto_cobrado"
                                   widget="monetary" options="{'currency_field': False}"/>
                            <field name="diferencia_incobrable" readonly="1"
                                   widget="monetary" options="{'currency_field': False}"/>
                        </group>
                    </group>

                    <group col="2">
                        <group string="Fechas">
                            <field name="fecha_declaracion"/>
                            <field name="fecha_baja_servicio"/>
                        </group>
                        <group string="Equipo">
                            <field name="equipo_retirado"/>
                            <field name="fecha_retiro_equipo"
                                   invisible="not equipo_retirado"/>
                        </group>
                    </group>

                    <field name="observaciones" string="Observaciones"
                           placeholder="Detalle de gestiones, condonaciones, acuerdos..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         SEARCH VIEW
    ══════════════════════════════════════════════════════════ -->
    <record id="view_incobrable_search" model="ir.ui.view">
        <field name="name">wigo.incobrable.search</field>
        <field name="model">wigo.incobrable</field>
        <field name="arch" type="xml">
            <search string="Buscar incobrables">
                <field name="partner_id" string="Cliente"/>
                <field name="codigo_cliente"/>
                <field name="meses_adeudados"/>
                <separator/>
                <filter name="activos" string="En gestión" domain="[('state','=','activo')]"/>
                <filter name="baja_incobrable" string="Baja Incobrable"
                        domain="[('state','=','baja_incobrable')]"/>
                <filter name="recuperados" string="Recuperados" domain="[('state','=','recuperado')]"/>
                <filter name="condonados" string="Condonados" domain="[('state','=','condonado')]"/>
                <separator/>
                <filter name="equipo_pendiente" string="Equipo no retirado"
                        domain="[('equipo_retirado','=',False),('state','=','baja_incobrable')]"/>
                <separator/>
                <filter name="group_state" string="Agrupar por Estado"
                        context="{'group_by': 'state'}"/>
                <filter name="group_plan" string="Agrupar por Plan"
                        context="{'group_by': 'plan_id'}"/>
            </search>
        </field>
    </record>

    <!-- Pivot para reportes -->
    <record id="view_incobrable_pivot" model="ir.ui.view">
        <field name="name">wigo.incobrable.pivot</field>
        <field name="model">wigo.incobrable</field>
        <field name="arch" type="xml">
            <pivot string="Resumen Incobrables">
                <field name="state" type="row"/>
                <field name="plan_id" type="col"/>
                <field name="monto_total_adeudado" type="measure"/>
                <field name="diferencia_incobrable" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         ACTION
    ══════════════════════════════════════════════════════════ -->
    <record id="action_incobrable" model="ir.actions.act_window">
        <field name="name">Incobrables</field>
        <field name="res_model">wigo.incobrable</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="search_view_id" ref="view_incobrable_search"/>
        <field name="context">{'search_default_activos': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay registros incobrables. ¡Excelente gestión!
            </p>
        </field>
    </record>

    <record id="action_incobrable_baja" model="ir.actions.act_window">
        <field name="name">Baja - Incobrables</field>
        <field name="res_model">wigo.incobrable</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_incobrable_search"/>
        <field name="domain">[('state','=','baja_incobrable')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay bajas por deuda incobrable.</p>
        </field>
    </record>

</odoo>
