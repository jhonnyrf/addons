<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_invoice_list" model="ir.ui.view">
        <field name="name">wigo.factura.cobranza.list</field>
        <field name="model">wigo.factura.cobranza</field>
        <field name="arch" type="xml">
            <list string="Facturas de Cobranza" decoration-success="state == 'emitido'" decoration-warning="state == 'pendiente'" decoration-danger="state == 'anulada'">
                <field name="numero_factura"/>
                <field name="partner_id"/>
                <field name="codigo_cliente" optional="show"/>
                <field name="razon_social" optional="show"/>
                <field name="nit_ci" optional="show"/>
                <field name="periodo_facturado"/>
                <field name="fecha_emision"/>
                <field name="monto_total" widget="monetary"/>
                <field name="descuento" optional="show" widget="monetary"/>
                <field name="monto_neto" widget="monetary"/>
                <field name="pago_id" optional="show"/>
                <field name="state" widget="badge" decoration-success="state == 'emitido'" decoration-warning="state == 'pendiente'" decoration-danger="state == 'anulada'"/>
            </list>
        </field>
    </record>

    <record id="view_invoice_form" model="ir.ui.view">
        <field name="name">wigo.factura.cobranza.form</field>
        <field name="model">wigo.factura.cobranza</field>
        <field name="arch" type="xml">
            <form string="Factura de Cobranza">
                <header>
                    <button name="action_marcar_pagada" string="Marcar Emitida" type="object" class="btn-primary" invisible="state != 'pendiente'"/>
                    <button name="action_anular" string="Anular" type="object" class="btn-danger" invisible="state == 'anulada'" confirm="¿Confirma anular esta factura?"/>
                    <field name="state" widget="statusbar" statusbar_visible="pendiente,emitido,anulada"/>
                    <field name="pago_id" invisible="1"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Emitida" bg_color="text-bg-success" invisible="state != 'emitido'"/>
                    <widget name="web_ribbon" title="Anulada" bg_color="text-bg-danger" invisible="state != 'anulada'"/>
                    <div class="oe_title">
                        <label for="numero_factura" string="Nº Factura"/>
                        <h1>
                            <field name="numero_factura"/>
                        </h1>
                        <h3>
                            <field name="numero_autorizacion" placeholder="Nº Autorización SIAT (opcional)"/>
                        </h3>
                    </div>
                    <group col="2">
                        <group string="Cliente / Pago origen">
                            <field name="pago_id" options="{'no_create': True}"/>
                            <field name="partner_id"/>
                            <field name="contract_id" domain="[('partner_id','=',partner_id)]"/>
                            <field name="codigo_cliente"/>
                        </group>
                        <group string="Datos de factura">
                            <field name="razon_social"/>
                            <field name="nit_ci"/>
                            <field name="fecha_emision"/>
                            <field name="periodo_facturado"/>
                        </group>
                    </group>
                    <group col="2">
                        <group string="Montos">
                            <field name="monto_total" widget="monetary"/>
                            <field name="descuento" widget="monetary"/>
                            <field name="monto_neto" readonly="1" widget="monetary"/>
                        </group>
                    </group>
                    <field name="notas" string="Notas" placeholder="Observaciones de la factura..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_invoice_form_emit" model="ir.ui.view">
        <field name="name">wigo.factura.cobranza.form.emit</field>
        <field name="model">wigo.factura.cobranza</field>
        <field name="arch" type="xml">
            <form string="Emitir Factura">
                <header>
                    <button name="action_anular" string="Anular" type="object" class="btn-danger" invisible="state != 'emitido'" confirm="¿Confirma anular esta factura?"/>
                    <field name="state" widget="statusbar" statusbar_visible="pendiente,emitido,anulada"/>
                    <field name="pago_id" invisible="1"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Emitida" bg_color="text-bg-success" invisible="state != 'emitido'"/>
                    <widget name="web_ribbon" title="Anulada" bg_color="text-bg-danger" invisible="state != 'anulada'"/>
                    <div class="oe_title">
                        <label for="numero_factura" string="Nº Factura"/>
                        <h2>
                            <field name="numero_factura" placeholder="Número de factura"/>
                        </h2>
                        <h3>
                            <field name="numero_autorizacion" placeholder="Nº Autorización SIAT (opcional)"/>
                        </h3>
                    </div>
                    <group col="2">
                        <group string="Cliente / Pago origen">
                            <field name="pago_id" options="{'no_create': True}"/>
                            <field name="partner_id"/>
                            <field name="contract_id" domain="[('partner_id','=',partner_id)]"/>
                            <field name="codigo_cliente"/>
                        </group>
                        <group string="Datos de factura">
                            <field name="razon_social"/>
                            <field name="nit_ci"/>
                            <field name="fecha_emision"/>
                            <field name="periodo_facturado"/>
                        </group>
                    </group>
                    <group col="2">
                        <group string="Montos">
                            <field name="monto_total" widget="monetary"/>
                            <field name="descuento" widget="monetary"/>
                            <field name="monto_neto" readonly="1" widget="monetary"/>
                        </group>
                    </group>
                    <field name="notas" string="Notas" placeholder="Observaciones de la factura..."/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_invoice_search" model="ir.ui.view">
        <field name="name">wigo.factura.cobranza.search</field>
        <field name="model">wigo.factura.cobranza</field>
        <field name="arch" type="xml">
            <search string="Buscar facturas">
                <field name="numero_factura"/>
                <field name="partner_id" string="Cliente"/>
                <field name="codigo_cliente"/>
                <field name="periodo_facturado"/>
                <separator/>
                <filter name="pending" string="Pendientes" domain="[('state','=','pendiente')]"/>
                <filter name="issued" string="Emitidas" domain="[('state','=','emitido')]"/>
                <filter name="cancelled" string="Anuladas" domain="[('state','=','anulada')]"/>
                <separator/>
                <filter name="current_month" string="Mes actual" domain="[('fecha_emision','&gt;=', context_today().replace(day=1).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter name="group_state" string="Agrupar por Estado" context="{'group_by': 'state'}"/>
                <filter name="group_period" string="Agrupar por Período" context="{'group_by': 'periodo_facturado'}"/>
            </search>
        </field>
    </record>

    <record id="view_invoice_pivot" model="ir.ui.view">
        <field name="name">wigo.factura.cobranza.pivot</field>
        <field name="model">wigo.factura.cobranza</field>
        <field name="arch" type="xml">
            <pivot string="Resumen Facturación">
                <field name="state" type="row"/>
                <field name="fecha_emision" type="col" interval="month"/>
                <field name="monto_neto" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_invoice" model="ir.actions.act_window">
        <field name="name">Facturación</field>
        <field name="res_model">wigo.factura.cobranza</field>
        <field name="view_mode">list,form,pivot</field>
        <field name="domain">[]</field>
        <field name="context">{'active_test': False}</field>
        <field name="search_view_id" ref="view_invoice_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay facturas registradas aún.
            </p>
            <p>Registra facturas de cobro vinculadas a los pagos de clientes.</p>
        </field>
    </record>

</odoo>
