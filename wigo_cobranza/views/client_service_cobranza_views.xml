<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         Inherited form: añadir pestaña Cobranza + estado_pago
         en la ficha técnica del cliente
    ══════════════════════════════════════════════════════════ -->
    <record id="view_ftth_cs_form_cobranza_inherit" model="ir.ui.view">
        <field name="name">wigo.ftth.client.service.form.cobranza</field>
        <field name="model">wigo.ftth.client.service</field>
        <field name="inherit_id" ref="wigo_ftth.view_ftth_cs_form"/>
        <field name="arch" type="xml">

            <!-- 1. Botón de stat en el button_box: acceso rápido a pagos -->
            <div name="button_box" position="inside">
                <button name="action_ver_pagos" type="object" class="oe_stat_button" icon="fa-money">
                    <field name="total_pagos" widget="statinfo" string="Pagos"/>
                </button>
            </div>

            <!-- 2. Semáforo de estado de pago visible junto al estado del servicio -->
            <field name="estado_servicio" position="after">
                <field name="estado_pago" widget="semaforo_pago" readonly="1" string="Estado de pago"/>
            </field>

            <!-- 3. Información de prorrateo en grupo datos del servicio -->
            <field name="fecha_instalacion" position="after">
                <field name="monto_prorrateo_primer_mes" readonly="1" string="Prorrateo primer mes (Bs)" help="Monto proporcional desde la fecha de instalación hasta fin de mes."/>
                <field name="ultimo_pago_fecha" readonly="1" string="Último pago registrado"/>
            </field>

            <!-- 4. Bloque Cobranza dentro del formulario -->
            <xpath expr="//notebook" position="inside">
                <page string="Cobranza">

                    <group>
                        <group string="Estado de pago" col="2">
                            <group>
                                <field name="estado_pago" widget="semaforo_pago" readonly="1"/>
                                <field name="ultimo_pago_fecha" readonly="1"/>
                            </group>
                            <group>
                                <field name="monto_prorrateo_primer_mes" readonly="1"/>
                            </group>
                        </group>
                    </group>

                    <div class="mb-3">
                        <button name="action_crear_pago_mes" type="object" string="+ Registrar Pago del Mes" class="btn-primary"/>
                    </div>

                    <field name="pago_ids" nolabel="1" readonly="1" context="{'default_client_service_id': id, 'default_partner_id': partner_id}">

                        <list string="Historial de pagos" decoration-success="estado_pago == 'al_dia'" decoration-warning="estado_pago in ['pendiente','deuda_parcial']" decoration-danger="estado_pago == 'mora'" decoration-muted="estado_pago == 'baja_definitiva'" editable="bottom">

                            <field name="periodo"/>
                            <field name="monto_a_cobrar" widget="monetary"/>
                            <field name="monto_pagado" widget="monetary"/>
                            <field name="fecha_pago"/>
                            <field name="canal_pago"/>
                            <field name="comprobante"/>
                            <field name="estado_pago" widget="badge" decoration-success="estado_pago == 'al_dia'" decoration-warning="estado_pago in ['pendiente','deuda_parcial']" decoration-danger="estado_pago == 'mora'"/>
                        </list>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════
         Inherited LIST view: añadir columna estado_pago
    ══════════════════════════════════════════════════════════ -->
    <record id="view_ftth_cs_list_cobranza_inherit" model="ir.ui.view">
        <field name="name">wigo.ftth.client.service.list.cobranza</field>
        <field name="model">wigo.ftth.client.service</field>
        <field name="inherit_id" ref="wigo_ftth.view_ftth_cs_list"/>
        <field name="arch" type="xml">
            <field name="estado_servicio" position="after">
                <field name="estado_pago" widget="badge" optional="show" decoration-success="estado_pago == 'al_dia'" decoration-warning="estado_pago in ['pendiente','deuda_parcial']" decoration-danger="estado_pago == 'mora'" decoration-muted="estado_pago == 'baja_definitiva'"/>
                <field name="ultimo_pago_fecha" optional="hide"/>
            </field>
        </field>
    </record>

</odoo>
