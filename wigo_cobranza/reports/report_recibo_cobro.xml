<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    Sub-template: A COPY of the receipt.
    It is called twice from the main template (original + duplicate).
    All variables (cp, cs, cfg, o, firma_*, etc.) come from the caller.
    -->
    <template id="report_recibo_una_copia">
        <div t-attf-style="
            font-family:#{ff};
            font-size:#{fb}px;
            color:#{ctp};
            border:1px solid #{cb};
            border-radius:#{rr}px;
            overflow:hidden;
            background:#{cfr};
        ">


            <div t-attf-style="#{hdr_bg} color:#{hdr_txt}; padding:8px 14px;">
                <table width="100%" cellpadding="0" cellspacing="0">
                    <tr>
                        <td valign="top" width="60%">
                            <div t-attf-style="font-size:#{ft}px; font-weight:#{fnb}; letter-spacing:-0.5px;">
                                RECIBO DE COBRANZA
                            </div>
                            <div t-attf-style="font-size:#{fe}px; font-weight:bold; margin-top:2px;">
                                <t t-out="cfg.empresa_nombre"/>
                            </div>
                            <t t-if="cfg.empresa_slogan">
                                <div style="font-size:10px; opacity:0.85; font-style:italic;">
                                    <t t-out="cfg.empresa_slogan"/>
                                </div>
                            </t>
                            <div style="font-size:9px; margin-top:2px; opacity:0.9; line-height:1.4;">
                                <t t-out="cfg.empresa_direccion"/>
                                <t t-if="cfg.empresa_ciudad">
                                    <br/>
                                    <t t-out="cfg.empresa_ciudad"/>
                                </t>
                                <t t-if="cfg.empresa_celular">
                                    <br/>
CEL: <t t-out="cfg.empresa_celular"/>
                                </t>
                                <t t-if="cfg.empresa_nit">
                                    &#160;|&#160; NIT: <t t-out="cfg.empresa_nit"/>
                                </t>
                            </div>
                        </td>
                        <td valign="top" width="40%" align="right">
                            <t t-if="cfg.logo">
                                <img t-att-src="image_data_uri(cfg.logo)" t-attf-style="max-height:#{la}px; max-width:#{int(la)*2}px; display:block; margin-left:auto;"/>
                            </t>
                            <t t-elif="company.logo">
                                <img t-att-src="image_data_uri(company.logo)" t-attf-style="max-height:#{la}px; max-width:#{int(la)*2}px; display:block; margin-left:auto;"/>
                            </t>
                            <div t-attf-style="font-size:16px; font-weight:bold; margin-top:4px; text-align:right;">
                                N&#176; <t t-out="o.numero"/>
                            </div>
                        </td>
                    </tr>
                </table>
            </div>

            <div style="padding:8px 14px;">

                <table width="100%" cellpadding="0" cellspacing="0" t-attf-style="margin-bottom:8px; padding-bottom:6px; border-bottom:1px solid #{cb};">
                    <tr>
                        <td width="60%" valign="top">
                            <div t-attf-style="font-size:9px; text-transform:uppercase; color:#{cts}; letter-spacing:0.8px; margin-bottom:1px;">
                                RECIBIDO DE:
                            </div>
                            <div t-attf-style="font-size:13px; font-weight:bold; color:#{ctp};">
                                <t t-out="o.partner_id.name"/>
                            </div>
                            <t t-if="cfg.mostrar_columna_codigo">
                                <div t-attf-style="font-size:10px; color:#{cts};">
                                    Código: <t t-out="o.codigo_cliente"/>
                                </div>
                            </t>
                        </td>
                        <td width="40%" valign="top" align="right">
                            <div t-attf-style="font-size:9px; text-transform:uppercase; color:#{cts}; letter-spacing:0.8px; margin-bottom:1px;">
                                FECHA:
                            </div>
                            <div t-attf-style="font-size:13px; font-weight:bold; color:#{cp};">
                                <t t-out="o.fecha_pago" t-options="{'widget':'date','format':'dd/MM/yyyy'}"/>
                            </div>
                            <div t-attf-style="font-size:10px; color:#{cts};">
                                <t t-out="o.periodo"/>
                            </div>
                        </td>
                    </tr>
                </table>

                <table width="100%" cellpadding="0" cellspacing="0" t-attf-style="border-collapse:collapse; font-size:#{fb}px; margin-bottom:6px;">
                    <thead>
                        <tr t-attf-style="background:#{cp}; color:#fff;">
                            <th style="padding:5px 8px; text-align:left;">
                                <t t-out="cfg.tabla_header_texto or 'DESCRIPCION'"/>
                            </th>
                            <th style="padding:5px 8px; text-align:right; width:110px; white-space:nowrap;">
                                <t t-out="cfg.tabla_monto_texto or 'PRECIO'"/>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td t-attf-style="padding:6px 8px; border-bottom:1px solid #{cb};">
                                <t t-out="o.descripcion"/>
                            </td>
                            <td t-attf-style="padding:6px 8px; text-align:right; border-bottom:1px solid #{cb};">
                                <t t-out="o.monto" t-options="{'widget':'float','precision':2}"/>
                            </td>
                        </tr>
                        <t t-if="cfg.mostrar_columna_codigo">
                            <tr>
                                <td t-attf-style="padding:4px 10px; font-size:10px; color:#{cts}; border-bottom:1px solid #{cb};">
                                    <t t-out="o.codigo_cliente"/>
                                </td>
                                <td t-attf-style="border-bottom:1px solid #{cb};"></td>
                            </tr>
                        </t>
                        <tr t-attf-style="background:#{cfm};">
                            <td t-attf-style="padding:5px 8px; font-size:10px; color:#{ctp};">
                                <span t-attf-style="font-weight:bold; text-transform:uppercase;">SON: </span>
                                <t t-out="o.monto_en_letras"/>
                            </td>
                            <td t-attf-style="padding:5px 8px; text-align:right; font-weight:bold; font-size:#{int(fb)+1}px; color:#{cp}; border-top:2px solid #{cp}; white-space:nowrap;">
                                TOTAL BS.&#160;&#160;<t t-out="o.monto" t-options="{'widget':'float','precision':2}"/>
                            </td>
                        </tr>
                    </tbody>
                </table>

                <t t-if="cfg.mostrar_banda_decorativa">
                    <div t-attf-style="background:#{cp}; height:#{cfg.ancho_banda or 8}px; border-radius:2px; margin:6px 0 8px 0;"/>
                </t>
                <t t-else="">
                    <div style="margin-bottom:10px;"/>
                </t>

                <table width="100%" cellpadding="0" cellspacing="0" style="margin-top:8px;">
                    <tr>
                        <td width="44%" valign="bottom">
                            <div style="height:22px;"></div>
                            <div t-attf-style="border-top:1px solid #{cb}; padding-top:6px; text-align:center;">
                                <div style="font-weight:bold; font-size:11px;">
                                    <t t-out="firma_nombre"/>
                                </div>
                                <div t-attf-style="font-size:10px; color:#{cts}; margin-top:2px;">
                                    <t t-out="firma_cargo"/>
                                </div>
                                <t t-if="firma_celular">
                                    <div t-attf-style="font-size:9px; color:#{cts};">
                                        CEL: <t t-out="firma_celular"/>
                                    </div>
                                </t>
                            </div>
                        </td>

                        <td width="12%"/>

                        <td width="44%" valign="bottom">
                            <div style="height:22px;"></div>
                            <div t-attf-style="border-top:1px solid #{cb}; padding-top:6px; text-align:center;">
                                <div style="font-weight:bold; font-size:11px;">ENTREGUE CONFORME</div>
                                <div t-attf-style="font-size:10px; color:#{cts}; margin-top:4px; text-align:left;">
                                    Nombre:&#160;_______________________________
                                </div>
                                <div t-attf-style="font-size:10px; color:#{cts}; margin-top:3px; text-align:left;">
                                    CI:&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;_______________________________
                                </div>
                            </div>
                        </td>
                    </tr>
                </table>

                <t t-if="cfg.mostrar_pie and cfg.texto_pie">
                    <div t-attf-style="text-align:center; margin-top:14px; font-size:10px;
                                           color:#{cts}; border-top:1px dashed #{cb}; padding-top:8px;">
                        <t t-out="cfg.texto_pie"/>
                    </div>
                </t>

            </div>
        </div>
    </template>


    <!-- ════════════════════════════════════════════════════════════
         MAIN TEMPLATE: Original + Copy (identical)
    ════════════════════════════════════════════════════════════ -->
    <template id="report_recibo_cobro_document">
        <t t-call="web.html_container">
            <meta charset="utf-8"/>
            <style>
                /* Eliminar espacios del header/footer de Odoo */
                @page { margin: 5mm; }
                body { margin: 0 !important; padding: 0 !important; }
                .header, .footer, #wkhtmltopdf_page_elements { display: none !important; }
                /* Asegurar que el contenido no tenga padding extra */
                .o_report_layout_standard { padding: 0 !important; }
            </style>

            <t t-foreach="docs" t-as="o">

                <t t-set="cfg" t-value="o.env['wigo.recibo.config'].get_config()"/>
                <t t-set="company" t-value="o.env.company"/>
                <t t-set="firma_nombre" t-value="o.firma_nombre_override or cfg.firma_nombre"/>
                <t t-set="firma_cargo" t-value="o.firma_cargo_override  or cfg.firma_cargo"/>
                <t t-set="firma_celular" t-value="o.firma_celular_override or cfg.firma_celular"/>

                <t t-set="cp" t-value="cfg.color_primario          or '#cc0000'"/>
                <t t-set="cs" t-value="cfg.color_secundario        or '#990000'"/>
                <t t-set="cht" t-value="cfg.color_texto_header      or '#ffffff'"/>
                <t t-set="cfr" t-value="cfg.color_fondo_recibo      or '#ffffff'"/>
                <t t-set="ctp" t-value="cfg.color_texto_principal   or '#222222'"/>
                <t t-set="cts" t-value="cfg.color_texto_secundario  or '#666666'"/>
                <t t-set="cb" t-value="cfg.color_borde             or '#cccccc'"/>
                <t t-set="cfm" t-value="cfg.color_fondo_monto       or '#f5f5f5'"/>

                <t t-set="ff" t-value="cfg.fuente_familia          or 'Arial, sans-serif'"/>
                <t t-set="fb" t-value="cfg.tamano_fuente_base      or 12"/>
                <t t-set="ft" t-value="cfg.tamano_titulo           or 22"/>
                <t t-set="fe" t-value="cfg.tamano_empresa          or 14"/>
                <t t-set="fnb" t-value="'bold' if cfg.fuente_titulo_negrita else 'normal'"/>
                <t t-set="rr" t-value="cfg.border_radius           or 0"/>
                <t t-set="la" t-value="cfg.logo_ancho              or 90"/>
                <t t-set="eh" t-value="cfg.estilo_header           or 'gradiente'"/>

                <t t-set="hdr_bg">
                    <t t-if="eh == 'gradiente'">background:linear-gradient(135deg,<t t-out="cp"/>
,                    <t t-out="cs"/>
);</t>
                <t t-elif="eh == 'solido'">background:<t t-out="cp"/>
;</t>
                <t t-elif="eh == 'linea'">background:transparent;border-bottom:3px solid <t t-out="cp"/>
;</t>
                <t t-else="">background:transparent;</t>
            </t>
            <t t-set="hdr_txt">
                <t t-if="eh == 'linea' or eh == 'sin_fondo'">
                    <t t-out="ctp"/>
                </t>
                <t t-else="">
                    <t t-out="cht"/>
                </t>
            </t>

            <div t-attf-style="font-family:#{ff}; font-size:#{fb}px; color:#{ctp}; max-width:780px; margin:auto; padding:2px 4px;">

                <t t-call="wigo_cobranza.report_recibo_una_copia"/>

                <div t-attf-style="text-align:center; font-size:9px; margin:4px 0;
                                           color:#{cts}; border-top:1px dashed #{cb};
                                           border-bottom:1px dashed #{cb}; padding:2px 0;">
                        - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
                </div>

                <t t-call="wigo_cobranza.report_recibo_una_copia"/>

            </div>
        </t>
    </t>
</template>


<!-- ════════════════════════════════════════════════════════════
      TEMPLATE: Only one copy (for individual printing)
    ════════════════════════════════════════════════════════════ -->
<template id="report_recibo_only_original">
    <t t-call="web.html_container">
        <meta charset="utf-8"/>
        <t t-foreach="docs" t-as="o">
            <t t-set="cfg" t-value="o.env['wigo.recibo.config'].get_config()"/>
            <t t-set="company" t-value="o.env.company"/>
            <t t-set="firma_nombre" t-value="o.firma_nombre_override or cfg.firma_nombre"/>
            <t t-set="firma_cargo" t-value="o.firma_cargo_override  or cfg.firma_cargo"/>
            <t t-set="firma_celular" t-value="o.firma_celular_override or cfg.firma_celular"/>
            <t t-set="cp" t-value="cfg.color_primario          or '#cc0000'"/>
            <t t-set="cs" t-value="cfg.color_secundario        or '#990000'"/>
            <t t-set="cht" t-value="cfg.color_texto_header      or '#ffffff'"/>
            <t t-set="cfr" t-value="cfg.color_fondo_recibo      or '#ffffff'"/>
            <t t-set="ctp" t-value="cfg.color_texto_principal   or '#222222'"/>
            <t t-set="cts" t-value="cfg.color_texto_secundario  or '#666666'"/>
            <t t-set="cb" t-value="cfg.color_borde             or '#cccccc'"/>
            <t t-set="cfm" t-value="cfg.color_fondo_monto       or '#f5f5f5'"/>
            <t t-set="ff" t-value="cfg.fuente_familia          or 'Arial, sans-serif'"/>
            <t t-set="fb" t-value="cfg.tamano_fuente_base      or 12"/>
            <t t-set="ft" t-value="cfg.tamano_titulo           or 22"/>
            <t t-set="fe" t-value="cfg.tamano_empresa          or 14"/>
            <t t-set="fnb" t-value="'bold' if cfg.fuente_titulo_negrita else 'normal'"/>
            <t t-set="rr" t-value="cfg.border_radius           or 0"/>
            <t t-set="la" t-value="cfg.logo_ancho              or 90"/>
            <t t-set="eh" t-value="cfg.estilo_header           or 'gradiente'"/>
            <t t-set="hdr_bg">
                <t t-if="eh == 'gradiente'">background:linear-gradient(135deg,<t t-out="cp"/>
,                <t t-out="cs"/>
);</t>
            <t t-elif="eh == 'solido'">background:<t t-out="cp"/>
;</t>
            <t t-elif="eh == 'linea'">background:transparent;border-bottom:3px solid <t t-out="cp"/>
;</t>
            <t t-else="">background:transparent;</t>
        </t>
        <t t-set="hdr_txt">
            <t t-if="eh == 'linea' or eh == 'sin_fondo'">
                <t t-out="ctp"/>
            </t>
            <t t-else="">
                <t t-out="cht"/>
            </t>
        </t>
        <div t-attf-style="font-family:#{ff}; font-size:#{fb}px; color:#{ctp}; max-width:780px; margin:auto; padding:6px;">
            <t t-call="wigo_cobranza.report_recibo_una_copia"/>
        </div>
    </t>
</t>
</template>


<!-- ════════════════════════════════════════════════════════════
         REPORT RECORDS
    ════════════════════════════════════════════════════════════ -->
<record id="action_report_recibo_cobro" model="ir.actions.report">
<field name="name">Recibo de Cobro</field>
<field name="model">wigo.recibo.cobro</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">wigo_cobranza.report_recibo_cobro_document</field>
<field name="report_file">wigo_cobranza.report_recibo_cobro_document</field>
<field name="paperformat_id" ref="wigo_cobranza.paperformat_recibo_cobro"/>
<field name="binding_model_id" ref="model_wigo_recibo_cobro"/>
<field name="binding_type">report</field>
</record>

<record id="action_report_recibo_cobro_original" model="ir.actions.report">
<field name="name">Recibo de Cobro — Solo Original</field>
<field name="model">wigo.recibo.cobro</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">wigo_cobranza.report_recibo_only_original</field>
<field name="report_file">wigo_cobranza.report_recibo_only_original</field>
<field name="paperformat_id" ref="wigo_cobranza.paperformat_recibo_cobro"/>
</record>

<record id="action_report_recibo_cobro_copia" model="ir.actions.report">
<field name="name">Recibo de Cobro — Copia</field>
<field name="model">wigo.recibo.cobro</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">wigo_cobranza.report_recibo_only_original</field>
<field name="report_file">wigo_cobranza.report_recibo_only_original</field>
</record>

</odoo>
