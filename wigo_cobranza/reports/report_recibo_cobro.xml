<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════
         TEMPLATE PREVIEW (HTML embebido en el formulario)
    ════════════════════════════════════════════════════════════ -->
    <template id="report_recibo_cobro_preview">
        <t t-set="cfg" t-value="doc.env['wigo.recibo.config'].get_config()"/>
        <t t-set="company" t-value="doc.env.company"/>
        <t t-set="firma_nombre" t-value="doc.firma_nombre_override or cfg.firma_nombre"/>
        <t t-set="firma_cargo" t-value="doc.firma_cargo_override or cfg.firma_cargo"/>
        <t t-set="firma_celular" t-value="doc.firma_celular_override or cfg.firma_celular"/>

        <div style="font-family: Arial, sans-serif; font-size: 11px; padding: 15px; background: #f5f5f5;">
            <!-- RECIBO ÚNICO PARA PREVIEW -->
            <div style="border: 1px solid #ddd; padding: 15px; background: white; margin-bottom: 10px;">

                <!-- HEADER CON LOGO Y TITULO -->
                <table width="100%" style="margin-bottom: 15px;">
                    <tr>
                        <td width="70%">
                            <div style="font-size: 18px; font-weight: bold; color: #cc0000;">
                                RECIBO DE COBRANZA
                            </div>
                            <div style="font-weight: bold; margin-top: 8px;">
                                <t t-esc="cfg.empresa_nombre"/>
                            </div>
                            <div style="font-size: 10px; color: #666;">
                                <t t-esc="cfg.empresa_direccion"/>
                                <br/>
                                <t t-esc="cfg.empresa_ciudad"/>
                                <br/>
                                CEL: <t t-esc="cfg.empresa_celular"/>
                            </div>
                        </td>
                        <td width="30%" style="text-align: right;">
                            <t t-if="company.logo">
                                <img t-att-src="image_data_uri(company.logo)" style="max-height: 50px;"/>
                            </t>
                            <t t-elif="cfg.logo">
                                <img t-att-src="image_data_uri(cfg.logo)" style="max-height: 50px;"/>
                            </t>
                            <div style="font-weight: bold; margin-top: 10px; font-size: 12px;">
                                Nº <t t-esc="doc.numero"/>
                            </div>
                        </td>
                    </tr>
                </table>

                <!-- DATOS PRINCIPALES -->
                <div style="margin: 15px 0; padding-bottom: 10px; border-bottom: 1px solid #eee;">
                    <div style="margin-bottom: 8px;">
                        <strong>RECIBIDO DE:</strong>
                        <span style="margin-left: 20px;">
                            <t t-esc="doc.partner_id.name"/>
                        </span>
                        <span style="margin-left: 30px; color: #cc0000;">
                            <strong>FECHA:</strong>
                            <t t-esc="doc.fecha_pago" t-options="{'widget':'date','format':'dd/MM/yyyy'}"/>
                        </span>
                    </div>
                    <div style="font-size: 10px; color: #666;">
                        Código: <t t-esc="doc.codigo_cliente"/>
                    </div>
                </div>

                <!-- TABLA DE DETALLES -->
                <table width="100%" style="margin: 15px 0; border-collapse: collapse;">
                    <thead>
                        <tr style="background: #cc0000; color: white;">
                            <th style="padding: 8px; text-align: left;">DESCRIPCIÓN</th>
                            <th style="padding: 8px; text-align: right; width: 100px;">MONTO</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr style="border-bottom: 1px solid #eee;">
                            <td style="padding: 10px;">
                                <t t-esc="doc.descripcion"/>
                            </td>
                            <td style="padding: 10px; text-align: right;">
                                <t t-esc="doc.monto" t-options="{'widget':'float','precision':2}"/>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 10px; font-size: 10px; color: #666;">
                                <t t-esc="doc.periodo or 'Servicio Internet'"/>
                            </td>
                            <td style="border-top: 2px solid #999; padding: 10px; text-align: right; font-weight: bold;">
                                <t t-esc="doc.monto" t-options="{'widget':'float','precision':2}"/>
 Bs.
                            </td>
                        </tr>
                    </tbody>
                </table>

                <!-- MONTO EN LETRAS -->
                <div style="padding: 12px; background: #f9f9f9; margin: 10px 0; border-left: 3px solid #cc0000;">
                    <strong>SON:</strong>
                    <t t-esc="doc.monto_en_letras"/>
                </div>

                <!-- FIRMA -->
                <div style="margin-top: 20px;">
                    <table width="100%">
                        <tr>
                            <td width="50%" style="text-align: center; border-top: 1px solid #999; padding-top: 20px;">
                                <div style="font-weight: bold;">
                                    <t t-esc="firma_nombre"/>
                                </div>
                                <div style="font-size: 10px;">
                                    <t t-esc="firma_cargo"/>
                                </div>
                                <div style="font-size: 9px; color: #666;">
                                    CEL: <t t-esc="firma_celular"/>
                                </div>
                            </td>
                            <td width="50%" style="text-align: center; border-top: 1px solid #999; padding-top: 20px;">
                                <div style="font-weight: bold; font-size: 12px;">
                                    ENTREGUE CONFORME
                                </div>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </template>

    <!-- ════════════════════════════════════════════════════════════
         TEMPLATE PDF (DOCUMENTO PARA IMPRIMIR)
    ════════════════════════════════════════════════════════════ -->
    <template id="report_recibo_cobro_document">
        <t t-call="web.html_container">
            <meta charset="utf-8"/>

            <t t-foreach="docs" t-as="o">
                <t t-set="cfg" t-value="o.env['wigo.recibo.config'].get_config()"/>
                <t t-set="company" t-value="o.env.company"/>

                <!-- Variables de firma: usar override si existe, sino config -->
                <t t-set="firma_nombre" t-value="o.firma_nombre_override or cfg.firma_nombre"/>
                <t t-set="firma_cargo" t-value="o.firma_cargo_override or cfg.firma_cargo"/>
                <t t-set="firma_celular" t-value="o.firma_celular_override or cfg.firma_celular"/>

                <div style="font-family: Arial; font-size: 12px; max-width:780px; margin:auto;">

                    <!-- =================== RECIBO ORIGINAL =================== -->
                    <div style="border:1px solid #ccc; padding:20px;">

                        <table width="100%">
                            <tr>
                                <td width="60%">
                                    <div style="font-size:26px; font-weight:bold;">RECIBO DE COBRANZA</div>
                                    <div>
                                        <b>
                                            <t t-esc="cfg.empresa_nombre"/>
                                        </b>
                                    </div>
                                    <div>
                                        <t t-esc="cfg.empresa_direccion"/>
                                    </div>
                                    <div>
                                        <t t-esc="cfg.empresa_ciudad"/>
                                    </div>
                                    <div>CEL: <t t-esc="cfg.empresa_celular"/>
                                    </div>
                                </td>

                                <td width="40%" align="right">
                                    <t t-if="company.logo">
                                        <img t-att-src="image_data_uri(company.logo)" style="max-height:70px;"/>
                                    </t>
                                    <t t-elif="cfg.logo">
                                        <img t-att-src="image_data_uri(cfg.logo)" style="max-height:70px;"/>
                                    </t>
                                    <div style="margin-top:10px; font-weight:bold;">
N&#176; <t t-esc="o.numero"/>
                                    </div>
                                </td>
                            </tr>
                        </table>

                        <div style="margin-top:10px;">
                            <b>RECIBIDO DE:</b>
                            <span style="margin-left:30px; color:red;">
FECHA:
                                <t t-esc="o.fecha_pago" t-options="{'widget':'date','format':'dd/MM/yyyy'}"/>
                            </span>
                        </div>

                        <div>Sr/Sra.: <b>
                            <t t-esc="o.partner_id.name"/>
                        </b>
                    </div>

                    <table width="100%" style="margin-top:10px; border-collapse:collapse;">
                        <thead>
                            <tr style="background:#cc0000; color:#fff;">
                                <th>DESCRIPCION</th>
                                <th>PRECIO</th>
                            </tr>
                        </thead>

                        <tbody>
                            <tr>
                                <td>
                                    <t t-esc="o.descripcion"/>
                                </td>
                                <td align="right">
                                    <t t-esc="o.monto" t-options="{'widget':'float','precision':2}"/>
                                </td>
                            </tr>

                            <tr>
                                <td>
                                    <t t-esc="o.codigo_cliente"/>
                                </td>
                                <td style="border-top:1px solid #999;"></td>
                            </tr>
                        </tbody>

                        <tfoot>
                            <tr>
                                <td>SON: <t t-esc="o.monto_en_letras"/>
                                </td>
                                <td align="right">
                                    <b>TOTAL Bs.</b>
                                    <t t-esc="o.monto" t-options="{'widget':'float','precision':2}"/>
                                </td>
                            </tr>
                        </tfoot>
                    </table>

                    <div style="background:#cc0000; height:10px; margin:10px 0;"></div>

                    <table width="100%">
                        <tr>
                            <td width="45%">
                                <b>
                                    <t t-esc="firma_nombre"/>
                                </b>
                                <br/>
                                <t t-esc="firma_cargo"/>
                                <br/>
CEL: <t t-esc="firma_celular"/>
                            </td>

                            <td width="10%"></td>

                            <td width="45%">
                                <b>ENTREGUE CONFORME</b>
                                <br/>
Nombre: ___________________<br/>
CI: ___________________
                            </td>
                        </tr>
                    </table>

                </div>

                <!-- =================== LINEA CORTE =================== -->
                <div style="text-align:center; font-size:10px; margin:8px 0; border-top:1px dashed #aaa; border-bottom:1px dashed #aaa;">
--- COPIA CLIENTE ---
                </div>

                <!-- =================== RECIBO COPIA =================== -->
                <div style="border:1px solid #ccc; padding:20px;">

                    <table width="100%">
                        <tr>
                            <td width="60%">
                                <div style="font-size:26px; font-weight:bold;">RECIBO DE COBRANZA</div>
                                <div>
                                    <b>
                                        <t t-esc="cfg.empresa_nombre"/>
                                    </b>
                                </div>
                                <div>
                                    <t t-esc="cfg.empresa_direccion"/>
                                </div>
                                <div>
                                    <t t-esc="cfg.empresa_ciudad"/>
                                </div>
                                <div>CEL: <t t-esc="cfg.empresa_celular"/>
                                </div>
                            </td>

                            <td width="40%" align="right">
                                <t t-if="company.logo">
                                    <img t-att-src="image_data_uri(company.logo)" style="max-height:70px;"/>
                                </t>
                                <t t-elif="cfg.logo">
                                    <img t-att-src="image_data_uri(cfg.logo)" style="max-height:70px;"/>
                                </t>
                                <div style="margin-top:10px; font-weight:bold;">
N&#176; <t t-esc="o.numero"/>
                                </div>
                            </td>
                        </tr>
                    </table>

                    <div style="margin-top:10px;">
                        <b>RECIBIDO DE:</b>
                        <span style="margin-left:30px; color:red;">
FECHA:
                            <t t-esc="o.fecha_pago" t-options="{'widget':'date','format':'dd/MM/yyyy'}"/>
                        </span>
                    </div>

                    <div>Sr/Sra.: <b>
                        <t t-esc="o.partner_id.name"/>
                    </b>
                </div>

                <table width="100%" style="margin-top:10px; border-collapse:collapse;">
                    <thead>
                        <tr style="background:#cc0000; color:#fff;">
                            <th>DESCRIPCION</th>
                            <th>PRECIO</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>
                                <t t-esc="o.descripcion"/>
                            </td>
                            <td align="right">
                                <t t-esc="o.monto" t-options="{'widget':'float','precision':2}"/>
                            </td>
                        </tr>

                        <tr>
                            <td>
                                <t t-esc="o.codigo_cliente"/>
                            </td>
                            <td style="border-top:1px solid #999;"></td>
                        </tr>
                    </tbody>

                    <tfoot>
                        <tr>
                            <td>SON: <t t-esc="o.monto_en_letras"/>
                            </td>
                            <td align="right">
                                <b>TOTAL Bs.</b>
                                <t t-esc="o.monto" t-options="{'widget':'float','precision':2}"/>
                            </td>
                        </tr>
                    </tfoot>
                </table>

                <div style="background:#cc0000; height:10px; margin:10px 0;"></div>

                <table width="100%">
                    <tr>
                        <td width="45%">
                            <b>
                                <t t-esc="firma_nombre"/>
                            </b>
                            <br/>
                            <t t-esc="firma_cargo"/>
                            <br/>
CEL: <t t-esc="firma_celular"/>
                        </td>

                        <td width="10%"></td>

                        <td width="45%">
                            <b>ENTREGUE CONFORME</b>
                            <br/>
Nombre: ___________________<br/>
CI:     ___________________
                        </td>
                    </tr>
                </table>

            </div>

        </div>
    </t>
</t>
</template>
<record id="action_report_recibo_cobro" model="ir.actions.report">
<field name="name">Recibo de Cobro</field>
<field name="model">wigo.recibo.cobro</field>
<field name="report_type">qweb-pdf</field>
<field name="report_name">wigo_cobranza.report_recibo_cobro_document</field>
<field name="report_file">wigo_cobranza.report_recibo_cobro_document</field>
<field name="binding_model_id" ref="model_wigo_recibo_cobro"/>
<field name="binding_type">report</field>
</record>

</odoo>