<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═════════════════════════════════════════════════════════
         WIZARD: VER RECIBO - OPCIONES DE IMPRESIÓN
         ═════════════════════════════════════════════════════════ -->
    <record id="view_recibo_viewer_form" model="ir.ui.view">
        <field name="name">recibo.viewer.form</field>
        <field name="model">recibo.viewer</field>
        <field name="arch" type="xml">
            <form string="Ver Recibo">
                <div class="alert alert-info">
                    <h5 class="mb-2">
                        <i class="fa fa-file-text-o me-2"/>
                        <strong>Recibo Nº <field name="numero_recibo" class="fw-bold" readonly="1"/>
                        </strong>
                    </h5>
                    <div class="row g-3">
                        <div class="col-sm-6">
                            <small>
                                <strong>Cliente:</strong>
                            </small>
                            <div>
                                <field name="partner_id" readonly="1"/>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <small>
                                <strong>Monto:</strong>
                            </small>
                            <div>
                                <field name="monto" readonly="1"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN DE OPCIONES -->
                <group>
                    <div class="card border-0">
                        <div class="card-header bg-primary text-white fw-bold">
                            <i class="fa fa-print me-2"/>
Opciones de Impresión
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <button name="action_imprimir_ambas" string="🖨️ Imprimir Ambas Copias (Original + Cliente)" type="object" class="btn btn-success btn-lg"/>
                                <button name="action_imprimir_original" string="📄 Imprimir Solo Original (Empresa)" type="object" class="btn btn-info btn-lg"/>
                                <button name="action_imprimir_copia" string="📋 Imprimir Solo Copia (Cliente)" type="object" class="btn btn-warning btn-lg"/>
                            </div>
                        </div>
                    </div>
                </group>

                <group>
                    <div class="card border-0">
                        <div class="card-header bg-secondary text-white fw-bold">
                            <i class="fa fa-cog me-2"/>
Opciones de Gestión
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <button name="action_editar" string="✏️ Editar Recibo" type="object" class="btn btn-warning btn-lg"/>
                                <button name="action_anular" string="❌ Anular Recibo" type="object" class="btn btn-danger btn-lg" confirm="¿Confirma anular este recibo?"/>
                            </div>
                        </div>
                    </div>
                </group>

                <footer class="pt-3 border-top">
                    <button string="Cerrar" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- ═════════════════════════════════════════════════════════
         ACCIÓN DEL WIZARD
         ═════════════════════════════════════════════════════════ -->
    <record id="action_recibo_viewer" model="ir.actions.act_window">
        <field name="name">Ver Recibo</field>
        <field name="res_model">recibo.viewer</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="wigo_cobranza.model_wigo_recibo_cobro"/>
        <field name="binding_view_types">form</field>
    </record>

</odoo>
