<odoo>

    <!-- Oculta bloques de empresa/contacto en la pestaña lead del formulario CRM. -->
    <record id="crm_lead_form_inherit_wigo_hide_groups" model="ir.ui.view">
        <field name="name">crm.lead.form.wigo.hide.groups</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- Oculta el grupo donde se muestra partner_name. -->
            <xpath expr="//page[@name='lead']//field[@name='partner_name']/ancestor::group[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Oculta el grupo donde se muestra contact_name. -->
            <xpath expr="//page[@name='lead']//field[@name='contact_name']/ancestor::group[1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Mueve el campo Etiquetas original junto a Vendedor para evitar duplicados. -->
            <xpath expr="(//field[@name='user_id'])[1]" position="after">
                <xpath expr="(//field[@name='tag_ids'])[1]" position="move"/>
            </xpath>

        </field>
    </record>

    <!-- Renombra la pestaña lead para reflejar el uso en Wigo. -->
    <record id="crm_lead_form_inherit_wigo_rename_tab" model="ir.ui.view">
        <field name="name">crm.lead.form.wigo.rename.tab</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='lead']" position="attributes">
                <attribute name="string">Información Adicional</attribute>
            </xpath>

        </field>
    </record>

    <!-- Ajuste de kanban: desactiva quick create para abrir formulario completo. -->
    <record id="crm_case_kanban_view_leads_wigo" model="ir.ui.view">
        <field name="name">crm.lead.kanban.wigo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_kanban_view_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="quick_create">false</attribute>
            </xpath>
        </field>
    </record>

    <!-- Reemplaza la lista base de oportunidades con columnas acordes al CRM de Wigo. -->
    <record id="crm_case_tree_view_oppor_wigo" model="ir.ui.view">
        <field name="name">crm.lead.list.opportunity.wigo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
        <field name="mode">primary</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace">
                <list string="Opportunities" sample="1" multi_edit="1">
                    <header>
                        <button name="%(crm.crm_lead_lost_action)d" type="action" string="Mark Lost"/>
                        <button name="%(crm.action_lead_mail_compose)d" type="action" string="Email"/>
                    </header>

                    <field name="company_id" column_invisible="True"/>
                    <field name="user_company_ids" column_invisible="True"/>
                    <field name="active" column_invisible="True"/>
                    <field name="company_currency" column_invisible="True"/>
                    <field name="color" column_invisible="True"/>
                    <field name="stage_id_color" column_invisible="True"/>
                    <field name="automated_probability" column_invisible="True"/>
                    <field name="message_bounce" column_invisible="True"/>

                    <field name="name" string="Oportunidad" readonly="1"/>
                    <field name="partner_id" string="Cliente" optional="show"/>
                    <field name="zona" optional="show"/>
                    <field name="codigo_cliente" string="Código contrato" optional="show"/>
                    <field name="contract_name" string="Contrato" optional="show"/>
                    <field name="contract_state" string="Estado contrato" optional="show"/>
                    <field name="contract_payment_mode" string="Pago" optional="show"/>
                    <field name="contract_plan_id" string="Plan contrato" optional="show"/>
                    <field name="telefono_contacto" string="Teléfono" optional="show"/>
                    <field name="user_id" optional="show" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                    <field name="team_id" optional="show"/>
                    <field name="priority" optional="hide" widget="priority"/>
                    <field name="activity_ids" optional="hide" widget="list_activity"/>
                    <field name="activity_user_id" optional="hide" string="Activity by" widget="many2one_avatar_user"/>
                    <field name="my_activity_date_deadline" optional="hide" string="My Deadline" widget="remaining_days" options="{'allow_order': '1'}"/>
                    <field name="stage_id" optional="show" widget="badge_rotting" options="{'no_open': True}"/>

                    <field name="date_deadline" column_invisible="True"/>
                    <field name="expected_revenue" column_invisible="True"/>
                    <field name="recurring_revenue_monthly" column_invisible="True"/>
                    <field name="campaign_id" column_invisible="True"/>
                    <field name="medium_id" column_invisible="True"/>
                    <field name="source_id" column_invisible="True"/>
                    <field name="probability" column_invisible="True"/>
                    <field name="lost_reason_id" column_invisible="True"/>
                    <field name="tag_ids" column_invisible="True"/>
                    <field name="lead_properties" column_invisible="True"/>
                    <field name="is_rotting" column_invisible="True"/>
                    <field name="rotting_days" column_invisible="True"/>
                </list>
            </xpath>
        </field>
    </record>

    <!-- Reemplaza la lista de leads para mostrar los datos personalizados que se usan en campo. -->
    <record id="crm_case_tree_view_leads_wigo" model="ir.ui.view">
        <field name="name">crm.lead.list.lead.wigo</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_case_tree_view_leads"/>
        <field name="mode">primary</field>
        <field name="priority">90</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="replace">
                <list string="Leads" sample="1" multi_edit="1">
                    <header>
                        <button name="%(crm.crm_lead_lost_action)d" type="action" string="Mark Lost"/>
                    </header>

                    <field name="company_id" column_invisible="True"/>
                    <field name="user_company_ids" column_invisible="True"/>
                    <field name="active" column_invisible="True"/>
                    <field name="company_currency" column_invisible="True"/>
                    <field name="color" column_invisible="True"/>
                    <field name="stage_id_color" column_invisible="True"/>

                    <field name="name" string="Lead" readonly="1"/>
                    <field name="partner_name" string="Cliente" optional="show"/>
                    <field name="contact_name" string="Contacto" optional="show"/>
                    <field name="email_from" optional="show"/>
                    <field name="telefono_contacto" string="Teléfono" optional="show"/>
                    <field name="zona" optional="show"/>
                    <field name="codigo_cliente" string="Código contrato" optional="show"/>
                    <field name="plan_id" string="Plan" optional="show"/>
                    <field name="direccion" optional="hide"/>
                    <field name="ubicacion" optional="hide"/>
                    <field name="coordenadas" optional="hide"/>
                    <field name="user_id" optional="show" widget="many2one_avatar_user" domain="[('share', '=', False)]"/>
                    <field name="team_id" optional="show"/>
                    <field name="priority" optional="hide" widget="priority"/>
                    <field name="activity_ids" optional="hide" widget="list_activity"/>
                    <field name="activity_user_id" optional="hide" string="Activity by" widget="many2one_avatar_user"/>
                    <field name="my_activity_date_deadline" optional="hide" string="My Deadline" widget="remaining_days" options="{'allow_order': '1'}"/>

                    <field name="date_deadline" column_invisible="True"/>
                    <field name="campaign_id" column_invisible="True"/>
                    <field name="medium_id" column_invisible="True"/>
                    <field name="source_id" column_invisible="True"/>
                    <field name="probability" column_invisible="True"/>
                    <field name="tag_ids" column_invisible="True"/>
                    <field name="lost_reason_id" column_invisible="True"/>
                    <field name="lead_properties" column_invisible="True"/>
                    <field name="message_needaction" column_invisible="True"/>
                </list>
            </xpath>
        </field>
    </record>

</odoo>