<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record model="res.groups.privilege" id="res_groups_privilege_wigo_crm">
            <field name="name">CRM Wigo</field>
            <field name="sequence">30</field>
            <field name="category_id" ref="base.module_category_sales"/>
        </record>
        
        <record id="group_wigo_crm_comercial" model="res.groups">
            <field name="name">CRM / Comercial</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('crm.group_use_lead')), (4, ref('sales_team.group_sale_salesman'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_wigo_crm"/>
        </record>

        <record id="group_wigo_crm_supervisor" model="res.groups">
            <field name="name">CRM / Técnica</field>
            <field name="implied_ids" eval="[(4, ref('group_wigo_crm_comercial'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_wigo_crm"/>
        </record>

        <record id="group_wigo_crm_config" model="res.groups">
            <field name="name">CRM / Contabilidad</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_wigo_crm"/>
        </record>

        <record id="group_wigo_crm_admin" model="res.groups">
            <field name="name">CRM / Administrador</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('crm.group_use_lead')), (4, ref('sales_team.group_sale_salesman')), (4, ref('sales_team.group_sale_manager'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_wigo_crm"/>
        </record>

        <record id="crm_lead_rule_accounting_won" model="ir.rule">
            <field name="name">CRM: contabilidad solo ve leads ganados</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="domain_force">[('stage_id.is_won', '=', True)]</field>
            <field name="groups" eval="[(4, ref('group_wigo_crm_config'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        
    </data>
</odoo>