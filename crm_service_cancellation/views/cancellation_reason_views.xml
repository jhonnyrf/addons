<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ LISTA DE MOTIVOS ═══ -->
    <record id="view_cancellation_reason_list" model="ir.ui.view">
        <field name="name">crm.cancellation.reason.list</field>
        <field name="model">crm.cancellation.reason</field>
        <field name="arch" type="xml">
            <list string="Motivos de baja" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ═══ FORMULARIO DE MOTIVO ═══ -->
    <record id="view_cancellation_reason_form" model="ir.ui.view">
        <field name="name">crm.cancellation.reason.form</field>
        <field name="model">crm.cancellation.reason</field>
        <field name="arch" type="xml">
            <form string="Motivo de Baja">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group string="Descripción interna">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ ACCIÓN ═══ -->
    <record id="action_cancellation_reason" model="ir.actions.act_window">
        <field name="name">Motivos de Baja</field>
        <field name="res_model">crm.cancellation.reason</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
