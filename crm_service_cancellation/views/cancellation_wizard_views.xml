<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cancellation_wizard_form" model="ir.ui.view">
        <field name="name">service.cancellation.wizard.form</field>
        <field name="model">service.cancellation.wizard</field>
        <field name="arch" type="xml">
            <form string="Baja de Servicio">

                <!-- ═══ Datos del cliente (readonly, autorellenados) ═══ -->
                <group string="Cliente">
                    <group>
                        <field name="partner_id" readonly="1"/>
                        <field name="ci_cliente" readonly="1" string="Carnet de identidad"/>
                        <field name="codigo_cliente" readonly="1"/>
                    </group>
                    <group>
                        <field name="contract_code" readonly="1" string="Código de contrato"/>
                        <field name="contract_state" readonly="1" widget="badge" decoration-info="contract_state == 'draft'" decoration-warning="contract_state == 'pending'" decoration-success="contract_state in ('signed', 'active')" decoration-muted="contract_state == 'terminated'" string="Estado del contrato"/>
                        <field name="plan_id" readonly="1"/>
                        <field name="contract_id" invisible="1"/>
                        <field name="lead_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                </group>

                <!-- ═══ Motivo de baja ═══ -->
                <group string="Motivo de baja">
                    <group>
                        <field name="reason_id" required="1" options="{'no_create_edit': False}" placeholder="Seleccionar o crear motivo..."/>
                        <field name="fecha_baja" required="1"/>
                    </group>
                    <field name="motivo_detalle" placeholder="Describe con más detalle el motivo si es necesario..."/>
                </group>

                <!-- ═══ Datos del ONU ═══ -->
                <group string="Equipo ONU">
                    <group>
                        <field name="onu_serial" placeholder="Ej. HWTC1A2B3C4D"/>
                        <field name="onu_mac" placeholder="Ej. 48:A7:2E:1F:00:01"/>
                        <field name="onu_modelo" placeholder="Ej. HG8310M"/>
                    </group>
                </group>

                <!-- ═══ Contrato y deuda (sección propia) ═══ -->
                <group string="Contrato y deuda">
                    <group>
                        <field name="terminar_contrato" invisible="not contract_code"/>
                        <field name="meses_deuda" help="0 = sin deuda. Se completará automáticamente con integración de facturación."/>
                        <field name="monto_deuda" invisible="meses_deuda == 0" required="meses_deuda &gt; 0"/>
                    </group>
                </group>

                <!-- ═══ Notas internas ═══ -->
                <group string="Notas internas">
                    <field name="notas" nolabel="1" placeholder="Observaciones adicionales..."/>
                </group>

                <footer>
                    <button name="action_confirm_cancellation" type="object" string="Confirmar baja" class="btn-danger" data-hotkey="q"/>
                    <button name="action_cancel" type="object" string="Cancelar" class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>
