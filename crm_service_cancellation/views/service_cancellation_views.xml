<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ LISTA ═══ -->
    <record id="view_service_cancellation_list" model="ir.ui.view">
        <field name="name">service.cancellation.list</field>
        <field name="model">service.cancellation</field>
        <field name="arch" type="xml">
            <list string="Bajas de servicio" create="0" decoration-danger="meses_deuda &gt; 0" decoration-muted="registrado_reporte == True">
                <field name="fecha_baja"/>
                <field name="partner_id"/>
                <field name="ci_cliente"/>
                <field name="codigo_cliente"/>
                <field name="plan_id"/>
                <field name="reason_id"/>
                <field name="ftth_estado_servicio" optional="show"/>
                <field name="cobranza_estado_pago" optional="show"/>
                <field name="meses_deuda"/>
                <field name="monto_deuda" optional="show"/>
                <field name="contrato_terminado" optional="show"/>
                <field name="registrado_reporte"/>
                <field name="contract_id" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ═══ FORMULARIO ═══ -->
    <record id="view_service_cancellation_form" model="ir.ui.view">
        <field name="name">service.cancellation.form</field>
        <field name="model">service.cancellation</field>
        <field name="arch" type="xml">
            <form string="Baja de Servicio" create="0">
                <header>
                    <button name="action_open_ftth_service" type="object" string="Ver ficha FTTH" class="btn-primary" icon="fa-wifi" invisible="not ftth_client_service_id"/>
                    <field name="registrado_reporte" widget="boolean_toggle" string="Registrado en reporte semanal"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>

                    <group string="Datos del cliente">
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="ci_cliente" readonly="1" string="Carnet de identidad"/>
                            <field name="codigo_cliente" readonly="1"/>
                            <field name="plan_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="lead_id" readonly="1"/>
                            <field name="contract_id" readonly="1"/>
                            <field name="contract_state_at_cancellation" readonly="1" string="Estado contrato al dar de baja"/>
                        </group>
                    </group>

                    <group string="Motivo de baja">
                        <group>
                            <field name="reason_id"/>
                            <field name="fecha_baja"/>
                        </group>
                        <field name="motivo_detalle"/>
                    </group>

                    <group string="Equipo ONU">
                        <group>
                            <field name="onu_equipo"/>
                            <field name="onu_rotulo"/>
                            <field name="onu_marca"/>
                            <field name="onu_serial"/>
                            <field name="onu_modelo"/>
                            <field name="onu_mac" invisible="1"/>
                        </group>
                        <group>
                            <field name="contrato_terminado"/>
                        </group>
                    </group>

                    <group string="Cobranza">
                        <group>
                            <field name="cobranza_estado_pago" readonly="1" widget="badge"
                                   decoration-success="cobranza_estado_pago == 'pagado'"
                                   decoration-warning="cobranza_estado_pago == 'pendiente'"
                                   decoration-danger="cobranza_estado_pago == 'mora'"/>
                        </group>
                        <group invisible="cobranza_estado_pago == 'mora'">
                            <field name="cobranza_ultimo_periodo_pagado" readonly="1"/>
                            <field name="cobranza_ultimo_pago_fecha" readonly="1"/>
                            <field name="cobranza_ultimo_monto_pagado" readonly="1"/>
                        </group>
                        <group invisible="cobranza_estado_pago != 'mora'">
                            <field name="cobranza_monto_deuda_total" readonly="1"/>
                            <field name="cobranza_dias_retraso" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ BÚSQUEDA ═══ -->
    <record id="view_service_cancellation_search" model="ir.ui.view">
        <field name="name">service.cancellation.search</field>
        <field name="model">service.cancellation</field>
        <field name="arch" type="xml">
            <search string="Buscar bajas">
                <field name="partner_id"/>
                <field name="codigo_cliente"/>
                <field name="ci_cliente"/>
                <field name="reason_id"/>
                <field name="fecha_baja"/>
                <separator/>
                <filter name="filter_deuda" string="Con deuda" domain="[('meses_deuda', '&gt;', 0)]"/>
                <filter name="filter_no_reporte" string="Sin registrar en reporte" domain="[('registrado_reporte', '=', False)]"/>
                <filter name="filter_contrato_terminado" string="Contrato terminado" domain="[('contrato_terminado', '=', True)]"/>
                <separator/>
                <filter name="group_motivo" string="Por motivo" context="{'group_by': 'reason_id'}"/>
                <filter name="group_fecha" string="Por mes de baja" context="{'group_by': 'fecha_baja:month'}"/>
            </search>
        </field>
    </record>

    <!-- ═══ ACCIÓN ═══ -->
    <record id="action_service_cancellation" model="ir.actions.act_window">
        <field name="name">Bajas de Servicio</field>
        <field name="res_model">service.cancellation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_service_cancellation_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay bajas registradas aún
            </p>
            <p>
                Las bajas se registran desde el botón
                <strong>"Dar de baja"</strong> en el CRM.
            </p>
        </field>
    </record>

</odoo>
