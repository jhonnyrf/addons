<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="navbar_apps_grid" inherit_id="web.NavBar.AppsMenu">
        <xpath expr="//t[@t-else='']/div[@class='o_navbar_apps_menu']/Dropdown/t[@t-set-slot='content']" position="replace">
            <t t-set-slot="content">
                <div class="wigo_apps_grid_dropdown">
                    <t t-foreach="apps" t-as="app" t-key="app.id">
                        <a class="wigo_app_card" t-att-href="getMenuItemHref(app)" t-att-data-menu-xmlid="app.xmlid" t-att-data-section="app.id" t-on-click.prevent="() => this.onNavBarDropdownItemSelection(app)">
                            <span class="wigo_app_icon_wrap">
                                <img t-if="app.webIconData" t-attf-src="{{app.webIconData}}" class="wigo_app_icon"/>
                                <i t-else="" class="oi oi-apps wigo_app_icon_fallback"/>
                            </span>
                            <span class="wigo_app_name" t-esc="app.name"/>
                        </a>
                    </t>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
