<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="wigo_visual_design.NavBar.AppsMenu" t-inherit="web.NavBar.AppsMenu" t-inherit-mode="extension">
        <xpath expr="//DropdownItem[@t-foreach='apps']" position="replace">
            <DropdownItem
              t-foreach="apps"
              t-as="app"
              t-key="app.id"
              class="{ 'o_app': true, focus: menuService.getCurrentApp() === app }"
              onSelected="() => this.onNavBarDropdownItemSelection(app)"
              attrs="{ href: getMenuItemHref(app), 'data-menu-xmlid': app.xmlid, 'data-section': app.id }"
            >
                <img t-if="app.webIconData" class="o_app_icon" t-attf-src="{{app.webIconData}}"/>
                <span class="o_app_name"><t t-esc="app.name"/></span>
            </DropdownItem>
        </xpath>
    </t>
</templates>
