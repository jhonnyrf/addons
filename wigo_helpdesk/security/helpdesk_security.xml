<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- Grupo: Agente Helpdesk -->
        <record id="group_helpdesk_user" model="res.groups">
            <field name="name">Helpdesk / Agente</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Grupo: Supervisor Helpdesk -->
        <record id="group_helpdesk_manager" model="res.groups">
            <field name="name">Helpdesk / Supervisor</field>
            <field name="implied_ids" eval="[(4, ref('group_helpdesk_user'))]"/>
        </record>

        <!-- Grupo: Administrador Helpdesk -->
        <record id="group_helpdesk_admin" model="res.groups">
            <field name="name">Helpdesk / Administrador</field>
            <field name="implied_ids" eval="[(4, ref('group_helpdesk_manager'))]"/>
        </record>

        <!-- Regla: Agente solo ve tickets asignados a él o que creó -->
        <record id="helpdesk_ticket_rule_user" model="ir.rule">
            <field name="name">Ticket: agente ve sus tickets y los de su equipo</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="domain_force">
                ['|', '|',
                    ('employee_id.user_id', '=', user.id),
                    ('user_id', '=', user.id),
                    ('create_uid', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Regla: Supervisor y Administrador ven todo -->
        <record id="helpdesk_ticket_rule_manager" model="ir.rule">
            <field name="name">Ticket: supervisor/admin ve todo</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
