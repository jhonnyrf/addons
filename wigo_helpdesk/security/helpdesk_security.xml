<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record model="res.groups.privilege" id="res_groups_privilege_helpdesk">
            <field name="name">Helpdesk</field>
            <field name="sequence">50</field>
            <field name="category_id" ref="base.module_category_services"/>
        </record>

        <!-- Regla: permitir lectura de HR Version a Helpdesk Técnica -->
        <record id="hr_version_helpdesk_rule" model="ir.rule">
            <field name="name">HR Version: allow helpdesk read</field>
            <field name="model_id" ref="hr.model_hr_version"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_manager')), (4, ref('group_helpdesk_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Grupo: Agente Helpdesk -->
        <record id="group_helpdesk_user" model="res.groups">
            <field name="name">Helpdesk / Comercial</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_helpdesk"/>
        </record>

        <!-- Grupo: Supervisor Helpdesk -->
        <record id="group_helpdesk_manager" model="res.groups">
            <field name="name">Helpdesk / Técnica</field>
            <field name="implied_ids" eval="[(4, ref('group_helpdesk_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_helpdesk"/>
        </record>

        <!-- Grupo: Administrador Helpdesk -->
        <record id="group_helpdesk_admin" model="res.groups">
            <field name="name">Helpdesk / Administrador</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="privilege_id" ref="res_groups_privilege_helpdesk"/>
        </record>

        <!-- Regla: Agente solo ve tickets asignados a él o que creó -->
        <record id="helpdesk_ticket_rule_user" model="ir.rule">
            <field name="name">Ticket: agente ve sus tickets y los de su equipo</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="domain_force">
                ['|', '|',
                    ('employee_id.user_id', '=', user.id),
                    ('user_id', '=', user.id),
                    ('create_uid', '=', user.id)
                ]
            </field>
            <field name="groups" eval="[(4, ref('group_helpdesk_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Regla: Supervisor y Administrador ven todo -->
        <record id="helpdesk_ticket_rule_manager" model="ir.rule">
            <field name="name">Ticket: supervisor/admin ve todo</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_helpdesk_manager')), (4, ref('group_helpdesk_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>

