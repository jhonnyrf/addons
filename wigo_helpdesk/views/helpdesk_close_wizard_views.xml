<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_close_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.close.wizard.form</field>
        <field name="model">helpdesk.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Cerrar / Registrar Postventa">
                <group>
                    <field name="ticket_id" readonly="1"/>
                </group>
                <group string="Resolución">
                    <field name="resolution_notes" nolabel="1"
                           placeholder="Describe brevemente cómo se resolvió el problema..."/>
                </group>
                <group string="Llamada Postventa">
                    <field name="postventa_done"/>
                    <field name="postventa_date" invisible="not postventa_done"/>
                    <field name="satisfaction" invisible="not postventa_done"/>
                    <field name="postventa_notes" invisible="not postventa_done"
                           placeholder="Observaciones de la llamada..."/>
                </group>
                <group>
                    <field name="close_ticket"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Confirmar" type="object"
                            class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>