        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="view_helpdesk_ticket_graph_by_diagnosis"/>
    </record>

    <record id="action_helpdesk_ticket_graph_symptom" model="ir.actions.act_window">
        <field name="name">Tickets por Síntoma</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="view_helpdesk_ticket_graph_by_symptom"/>
    </record>

    <record id="action_helpdesk_ticket_graph_solution" model="ir.actions.act_window">
        <field name="name">Tickets por Solución</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="view_helpdesk_ticket_graph_by_solution"/>
    </record>

    <record id="action_helpdesk_ticket_graph_month" model="ir.actions.act_window">
        <field name="name">Tickets por Mes</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="view_helpdesk_ticket_graph_by_month"/>
    </record>

    <record id="action_helpdesk_ticket_graph_customers" model="ir.actions.act_window">
