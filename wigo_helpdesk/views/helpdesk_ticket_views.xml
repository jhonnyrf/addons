        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">graph,list</field>
        <field name="view_id" ref="view_helpdesk_ticket_graph_by_customer"/>
    </record>

    <record id="action_helpdesk_ticket_my" model="ir.actions.act_window">
        <field name="name">Mis Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">['|', ('employee_id.user_id', '=', uid), ('user_id', '=', uid)]</field>
    </record>

    <record id="action_helpdesk_ticket_open" model="ir.actions.act_window">
        <field name="name">Tablero Kanban</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('is_closed', '=', False)]</field>
        <field name="context">{'search_default_filter_my': 1}</field>
    </record>

    <record id="action_helpdesk_ticket_sla" model="ir.actions.act_window">
        <field name="name">SLA Vencido</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('sla_status', '=', 'danger'), ('is_closed', '=', False)]</field>
    </record>

    <record id="action_helpdesk_ticket_visit" model="ir.actions.act_window">
        <field name="name">Visitas Pendientes</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('requires_visit', '=', True), ('visit_result', 'in', ('pending', 'in_progress', 'rescheduled')), ('is_closed', '=', False)]</field>
    </record>

    <record id="action_helpdesk_ticket_postventa" model="ir.actions.act_window">
        <field name="name">Postventa Pendiente</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('postventa_done', '=', False), ('is_closed', '=', True)]</field>
    </record>

    <record id="view_helpdesk_recurrent_partner_list" model="ir.ui.view">
        <field name="name">res.partner.helpdesk.recurrent.list</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <list string="Clientes Recurrentes">
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="helpdesk_ticket_count" string="Tickets"/>
                <field name="contract_count" string="Contratos"/>
            </list>
        </field>
    </record>

    <record id="action_helpdesk_ticket_recurrent_customers" model="ir.actions.act_window">
        <field name="name">Clientes Recurrentes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="wigo_helpdesk.view_helpdesk_recurrent_partner_list"/>
        <field name="domain">[('helpdesk_ticket_count', '&gt;', 1)]</field>
    </record>

