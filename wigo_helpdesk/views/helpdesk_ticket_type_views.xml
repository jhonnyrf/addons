<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TIPOS DE TICKETS — lista editable -->
    <record id="view_helpdesk_ticket_type_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.list</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <list string="Tipos de Tickets" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="color" widget="color_picker"/>
                <field name="ticket_count" readonly="1"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- TIPOS DE TICKETS — formulario completo -->
    <record id="view_helpdesk_ticket_type_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.type.form</field>
        <field name="model">helpdesk.ticket.type</field>
        <field name="arch" type="xml">
            <form string="Tipo de Ticket">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Tipo de Ticket"/>
                        <h1>
                            <field name="name" placeholder="Ej: Reclamo, Solicitud..."/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" widget="color_picker"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1" placeholder="Descripción del tipo de ticket..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACCIÓN para abrir tipos de tickets -->
    <record id="action_helpdesk_ticket_type" model="ir.actions.act_window">
        <field name="name">Tipos de Tickets</field>
        <field name="res_model">helpdesk.ticket.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
