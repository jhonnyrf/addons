<?xml version="1.0" encoding="utf-8"?>
<odoo>

        <record id="view_helpdesk_ticket_search" model="ir.ui.view">
                <field name="name">helpdesk.ticket.search</field>
                <field name="model">helpdesk.ticket</field>
                <field name="arch" type="xml">
                        <search>
                                <field name="title"/>
                                <field name="name"/>
                                <field name="customer_code"/>
                                <field name="customer_name"/>
                                <field name="customer_ci"/>
                                <field name="customer_phone"/>
                                <field name="stage_id"/>
                                <field name="area_id"/>
                                <field name="employee_id"/>
                                <field name="partner_id"/>
                                <field name="contract_id"/>
                                <field name="incident_type" string="Sintoma"/>
                                <field name="resolution_diagnosis_id" string="Diagnóstico"/>
                                <field name="resolution_solution_id" string="Solución"/>

                                <filter name="filter_open" string="Abiertos" domain="[('is_closed', '=', False)]"/>
                                <filter name="filter_closed" string="Cerrados" domain="[('is_closed', '=', True)]"/>
                                <separator/>
                                <filter name="filter_incident" string="Reclamos / Incidentes" domain="[('ticket_type_id.code', '=', 'incident')]"/>
                                <filter name="filter_request" string="Solicitudes" domain="[('ticket_type_id.code', '=', 'request')]"/>
                                <separator/>
                                <filter name="filter_sla_danger" string="SLA Vencido" domain="[('sla_status', '=', 'danger'), ('is_closed', '=', False)]"/>
                                <filter name="filter_sla_warning" string="SLA Próximo a vencer" domain="[('sla_status', '=', 'warning'), ('is_closed', '=', False)]"/>
                                <separator/>
                                <filter name="filter_my" string="Mis Tickets" domain="['|', ('employee_id.user_id', '=', uid), ('user_id', '=', uid)]"/>
                                <filter name="filter_critical" string="Prioridad Crítica" domain="[('priority', '=', '3')]"/>
                                <filter name="filter_escalated" string="Escalados" domain="[('is_escalated', '=', True)]"/>
                                <filter name="filter_postventa" string="Sin Postventa" domain="[('postventa_done', '=', False), ('is_closed', '=', True)]"/>
                                <separator/>
                                <!-- Filtros por mes -->
                                <filter name="filter_this_month" string="Este Mes" domain="[('create_date', '&gt;=', context_today().strftime('%Y-%m-01'))]"/>
                                <filter name="filter_this_month_panel" string="Este Mes (Panel)" domain="[('create_year', '=', context_today().strftime('%Y')), ('create_month', '=', context_today().strftime('%m'))]"/>
                                <filter name="filter_last_month" string="Todo (Sin filtro de mes)" domain="[]"/>

                                <group>
                                        <filter name="group_stage" string="Etapa" context="{'group_by': 'stage_id'}"/>
                                        <filter name="group_ticket_type" string="Tipo de Ticket" context="{'group_by': 'ticket_type'}"/>
                                        <filter name="group_incident" string="Síntoma" context="{'group_by': 'incident_type_id'}"/>
                                        <filter name="group_diagnosis" string="Diagnóstico" context="{'group_by': 'resolution_diagnosis_id'}"/>
                                        <filter name="group_solution" string="Solución" context="{'group_by': 'resolution_solution_id'}"/>
                                        <filter name="group_team" string="Área" context="{'group_by': 'area_id'}"/>
                                        <filter name="group_user" string="Asignado a" context="{'group_by': 'employee_id'}"/>
                                        <filter name="group_priority" string="Prioridad" context="{'group_by': 'priority'}"/>
                                        <filter name="group_zone" string="Zona" context="{'group_by': 'customer_zone'}"/>
                                        <filter name="group_sla_status" string="Estado SLA" context="{'group_by': 'sla_status'}"/>
                                        <filter name="group_channel" string="Canal" context="{'group_by': 'channel'}"/>
                                        <filter name="group_date" string="Fecha de Creación" context="{'group_by': 'create_date:month'}"/>
                                </group>
                                
                                <searchpanel>
                                        <field name="create_year" select="multi" icon="fa-calendar" expand="0"/>
                                        <field name="create_month" select="multi" icon="fa-calendar-o" expand="0"/>
                                        <field name="area_id" select="multi" icon="fa-users" enable_counters="1" expand="0"/>
                                        <field name="ticket_type_id" select="multi" icon="fa-tags" enable_counters="1" expand="0"/>
                                </searchpanel>
                        </search>
                </field>
        </record>

</odoo>
