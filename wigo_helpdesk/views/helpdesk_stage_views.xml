<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ETAPAS — lista editable -->
    <record id="view_helpdesk_stage_list" model="ir.ui.view">
        <field name="name">helpdesk.stage.list</field>
        <field name="model">helpdesk.stage</field>
        <field name="arch" type="xml">
            <list string="Etapas" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="description"/>
                <field name="is_close"/>
                <field name="fold"/>
                <field name="color" widget="color_picker"/>
                <field name="ticket_count" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- ETAPAS — formulario completo -->
    <record id="view_helpdesk_stage_form" model="ir.ui.view">
        <field name="name">helpdesk.stage.form</field>
        <field name="model">helpdesk.stage</field>
        <field name="arch" type="xml">
            <form string="Etapa">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Ej: En Atención, Resuelto..."/>
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                        <group>
                            <field name="is_close"
                                   help="Los tickets en esta etapa se consideran cerrados."/>
                            <field name="fold"
                                   help="Aparece plegada en el tablero Kanban."/>
                            <field name="ticket_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1"
                               placeholder="Descripción de cuándo usar esta etapa..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_stage" model="ir.actions.act_window">
        <field name="name">Etapas</field>
        <field name="res_model">helpdesk.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- CATEGORÍAS — lista editable -->
    <record id="view_helpdesk_category_list" model="ir.ui.view">
        <field name="name">helpdesk.category.list</field>
        <field name="model">helpdesk.category</field>
        <field name="arch" type="xml">
            <list string="Categorías" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="area"/>
                <field name="sla_hours" string="SLA (horas)"/>
                <field name="color" widget="color_picker"/>
                <field name="ticket_count" readonly="1"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- CATEGORÍAS — formulario -->
    <record id="view_helpdesk_category_form" model="ir.ui.view">
        <field name="name">helpdesk.category.form</field>
        <field name="model">helpdesk.category</field>
        <field name="arch" type="xml">
            <form string="Categoría">
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="Ej: Sin Servicio, Velocidad Baja..."/>
                            <field name="code" placeholder="Ej: TEC-01"/>
                            <field name="area"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="sla_hours"
                                   help="Horas máximas de resolución. 0 = usar SLA por prioridad del ticket."/>
                            <field name="color" widget="color_picker"/>
                            <field name="sequence"/>
                            <field name="ticket_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1"
                               placeholder="¿Cuándo usar esta categoría?..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_category" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">helpdesk.category</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
