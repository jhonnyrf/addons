<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_knowledge_list" model="ir.ui.view">
        <field name="name">helpdesk.knowledge.list</field>
        <field name="model">helpdesk.knowledge</field>
        <field name="arch" type="xml">
            <list string="Base de Conocimiento">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="ticket_type_id"/>
                <field name="area_id"/>
                <field name="author_id" widget="many2one_avatar_user"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_knowledge_form" model="ir.ui.view">
        <field name="name">helpdesk.knowledge.form</field>
        <field name="model">helpdesk.knowledge</field>
        <field name="arch" type="xml">
            <form string="Artículo de Conocimiento">
                <sheet>
                    <div class="oe_title mb-4">
                        <h1 class="w-100" style="border-bottom: 2px solid #007bff; padding-bottom: 10px;">
                            <i class="fa fa-book me-2" style="color: #007bff;"/>
                            <field name="name" placeholder="Título del artículo..." class="text-primary" style="font-weight: 600; font-size: 1.5rem;"/>
                        </h1>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="p-3 border rounded" style="background-color: #f8f9fa;">
                                <h6 class="text-primary mb-3" style="font-weight: 600;">
                                    <i class="fa fa-info-circle me-2"/>
Información Básica</h6>
                                <group>
                                    <field name="ticket_type_id" string="Tipo de Ticket"/>
                                    <field name="area_id" string="Departamento"/>
                                    <field name="author_id" widget="many2one_avatar_user" string="Autor"/>
                                    <field name="active" string="Activo"/>
                                </group>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded" style="background-color: #f0f8ff;">
                                <h6 class="text-info mb-3" style="font-weight: 600;">
                                    <i class="fa fa-shield me-2"/>
Metadatos</h6>
                                <group>
                                    <field name="create_date" string="Creado" readonly="1"/>
                                    <field name="write_date" string="Actualizado" readonly="1"/>
                                </group>
                            </div>
                        </div>
                    </div>
                    <div class="p-3 border rounded" style="background-color: #fffaf0; border-left: 4px solid #ff9800;">
                        <h6 class="text-warning mb-3" style="font-weight: 600;">
                            <i class="fa fa-file-text me-2"/>
Contenido del Artículo</h6>
                        <field name="content" nolabel="1" style="min-height: 400px; border: 1px solid #ddd; padding: 15px; background-color: white; border-radius: 4px;"/>
                    </div>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_knowledge_search" model="ir.ui.view">
        <field name="name">helpdesk.knowledge.search</field>
        <field name="model">helpdesk.knowledge</field>
        <field name="arch" type="xml">
            <search>
                <searchpanel enable_counters="true">
                    <field name="ticket_type_id" select="groupby" icon="fa-tags"/>
                    <field name="area_id" select="groupby" icon="fa-folder-o"/>
                </searchpanel>
                <field name="name"/>
                <field name="ticket_type_id"/>
                <field name="area_id"/>
                <group>
                    <filter string="Tipo de Ticket" name="group_ticket_type" context="{'group_by': 'ticket_type_id'}"/>
                    <filter string="Departamento" name="group_area_id" context="{'group_by': 'area_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_helpdesk_knowledge" model="ir.actions.act_window">
        <field name="name">Base de Conocimiento</field>
        <field name="res_model">helpdesk.knowledge</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_knowledge_search"/>
    </record>

</odoo>
