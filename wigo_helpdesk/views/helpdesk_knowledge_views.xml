<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_knowledge_list" model="ir.ui.view">
        <field name="name">helpdesk.knowledge.list</field>
        <field name="model">helpdesk.knowledge</field>
        <field name="arch" type="xml">
            <list string="Base de Conocimiento">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="area"/>
                <field name="author_id" widget="many2one_avatar_user"/>
                <field name="views" readonly="1"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_knowledge_form" model="ir.ui.view">
        <field name="name">helpdesk.knowledge.form</field>
        <field name="model">helpdesk.knowledge</field>
        <field name="arch" type="xml">
            <form string="Artículo de Conocimiento">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="category_id"/>
                            <field name="area"/>
                            <field name="author_id" widget="many2one_avatar_user"/>
                        </group>
                        <group>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="incident_type_ids" widget="many2many_tags" context="{'form_view_ref': 'wigo_helpdesk.view_helpdesk_incident_type_form'}" options="{'no_create_edit': False}"/>
                            <field name="views" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contenido">
                            <field name="content" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_knowledge_search" model="ir.ui.view">
        <field name="name">helpdesk.knowledge.search</field>
        <field name="model">helpdesk.knowledge</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="category_id"/>
                <filter string="Técnica" name="technical" domain="[('area', 'in', ['technical', 'both'])]"/>
                <filter string="Comercial" name="commercial" domain="[('area', 'in', ['commercial', 'both'])]"/>
                <group>
                    <filter string="Categoría" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Área" name="group_area" context="{'group_by': 'area'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_helpdesk_knowledge" model="ir.actions.act_window">
        <field name="name">Base de Conocimiento</field>
        <field name="res_model">helpdesk.knowledge</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_knowledge_search"/>
    </record>

</odoo>
