<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_sla_config_form" model="ir.ui.view">
        <field name="name">helpdesk.sla.config.form</field>
        <field name="model">helpdesk.sla.config</field>
        <field name="arch" type="xml">
            <form string="Semáforo SLA" close_button="1" create="false">
                <header>
                    <button name="action_regenerate_priorities" string="Restablecer configuración" type="object" class="btn-secondary" icon="fa-undo" confirm="¿Restablecer toda la configuración? Se perderán los cambios." />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Configuración del Semáforo SLA</h1>
                        <field name="name" invisible="1"/>
                    </div>

                    <!-- ══ PRIORIDADES SLA ══ -->
                    <separator string="Tiempos límite por prioridad"/>
                    <field name="priority_sla_ids" nolabel="1">
                        <list editable="bottom" string="Prioridades SLA">
                            <field name="sequence" widget="handle"/>
                            <field name="name" string="Prioridad"/>
                            <field name="color" widget="color" string="Color"/>
                            <field name="hours_limit" string="Horas límite"/>
                            <field name="attention_time" string="Tiempo de atención"/>
                            <field name="active" string="Activo" optional="show"/>
                        </list>
                    </field>

                    <!-- ══ UMBRAL AMARILLO ══ -->
                    <group string="¿Cuándo pasa a amarillo?">
                        <field name="warning_threshold_pct" string="Cuando quede menos del (%) del tiempo total"/>
                        <field name="warning_threshold_hours" string="O cuando queden menos de N horas (0 = ignorar)"/>
                    </group>

                    <!-- ══ ETIQUETAS SEMÁFORO ══ -->
                    <group string="Etiquetas del semáforo">
                        <group string="Verde · En tiempo">
                            <field name="ok_label" string="Etiqueta"/>
                            <field name="ok_color" widget="color" string="Color"/>
                        </group>
                        <group string="Amarillo · Advertencia">
                            <field name="warning_label" string="Etiqueta"/>
                            <field name="warning_color" widget="color" string="Color"/>
                        </group>
                        <group string="Rojo · Vencido">
                            <field name="danger_label" string="Etiqueta"/>
                            <field name="danger_color" widget="color" string="Color"/>
                        </group>
                        <group string="Gris · Cerrado">
                            <field name="closed_label" string="Etiqueta"/>
                            <field name="closed_color" widget="color" string="Color"/>
                        </group>
                    </group>

                    <!-- ══ AUTOMATIZACIONES ══ -->
                    <group string="Automatizaciones">
                        <field name="escalate_on_expire" string="Escalar ticket automáticamente al vencer el SLA"/>
                        <field name="notify_on_warning" string="Notificar al responsable cuando entre en zona amarilla"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_sla_config_list" model="ir.ui.view">
        <field name="name">helpdesk.sla.config.list</field>
        <field name="model">helpdesk.sla.config</field>
        <field name="arch" type="xml">
            <list string="Configuración SLA" create="false" delete="false" edit="false">
                <field name="name"/>
                <field name="warning_threshold_pct" string="Umbral amarillo (%)"/>
            </list>
        </field>
    </record>

    <record id="action_helpdesk_sla_config_prepare" model="ir.actions.server">
        <field name="name">Preparar y Abrir Semáforo SLA</field>
        <field name="model_id" ref="model_helpdesk_sla_config"/>
        <field name="state">code</field>
        <field name="code">
config = env['helpdesk.sla.config'].get_config()
config._ensure_default_priorities(config.id)
action = {
    'type': 'ir.actions.act_window',
    'name': '🚦 Semáforo SLA',
    'res_model': 'helpdesk.sla.config',
    'view_mode': 'form',
    'res_id': config.id,
    'target': 'current',
}
        </field>
    </record>

    <record id="action_helpdesk_sla_config" model="ir.actions.act_window">
        <field name="name">Semáforo SLA</field>
        <field name="res_model">helpdesk.sla.config</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="context">{'create': False, 'delete': False, 'edit': True}</field>
        <field name="domain">[('id', '>', 0)]</field>
    </record>

</odoo>
