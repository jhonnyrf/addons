<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         HERENCIA DE VISTA CONTACTO — Pestaña de Tickets del Cliente
    ====================================================================== -->
    <record id="view_res_partner_helpdesk_form" model="ir.ui.view">
        <field name="name">res.partner.helpdesk.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="🎫 Tickets Helpdesk" name="helpdesk_tickets">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold text-muted">Historial de tickets asociados a este contacto</span>
                    </div>
                    <field name="helpdesk_ticket_ids" nolabel="1" mode="list">
                        <list string="Tickets" decoration-danger="sla_status == 'danger' and not is_closed" decoration-warning="sla_status == 'warning' and not is_closed" decoration-success="is_closed">
                            <field name="name" string="N°" optional="show"/>
                            <field name="title" string="Título"/>
                            <field name="ticket_type" string="Tipo" optional="show"/>
                            <field name="incident_type_id" string="Síntoma" optional="show"/>
                            <field name="stage_id" string="Etapa" optional="show"/>
                            <field name="priority" widget="priority" optional="show"/>
                            <field name="employee_id" string="Asignado a" optional="show"/>
                            <field name="sla_deadline" string="⏳ Límite SLA" optional="show"/>
                            <field name="sla_status" string="🚦 SLA" optional="show" decoration-danger="sla_status == 'danger'" decoration-warning="sla_status == 'warning'" decoration-success="sla_status == 'ok'" decoration-muted="sla_status == 'closed'"/>
                            <field name="create_date" string="Fecha" optional="show"/>
                            <field name="is_closed" column_invisible="True"/>
                        </list>
                    </field>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
