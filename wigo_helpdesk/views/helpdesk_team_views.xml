<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- SEARCH VIEW para ÁREAS -->
    <record id="view_helpdesk_team_search" model="ir.ui.view">
        <field name="name">helpdesk.team.search</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <search string="Áreas">
                <searchpanel enable_counters="true">
                    <field name="area" select="groupby" icon="fa-folder-o"/>
                </searchpanel>
                <field name="name"/>
                <field name="area"/>
                <field name="active"/>
            </search>
        </field>
    </record>

    <!-- =====================================================================
            ÁREAS
        ====================================================================== -->
    <record id="view_helpdesk_team_list" model="ir.ui.view">
        <field name="name">helpdesk.team.list</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <list string="Áreas">
                <field name="name"/>
                <field name="area"/>
                <field name="team_leader_id" widget="many2one_avatar_user"/>
                <field name="team_email"/>
                <field name="team_phone"/>
                <field name="ticket_count" readonly="1"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_helpdesk_team_form" model="ir.ui.view">
        <field name="name">helpdesk.team.form</field>
        <field name="model">helpdesk.team</field>
        <field name="arch" type="xml">
            <form string="Área">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_tickets" class="oe_stat_button" icon="fa-ticket">
                            <field name="ticket_count" widget="statinfo" string="Tickets Abiertos"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="area"/>
                            <field name="team_leader_id" widget="many2one_avatar_user"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="team_email" widget="email"/>
                            <field name="team_phone" widget="phone"/>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                    <group string="Miembros del Área">
                        <field name="member_ids" widget="many2many_tags" options="{'color_field': 'color'}" nolabel="1"/>
                    </group>
                    <group string="Descripción">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_team" model="ir.actions.act_window">
        <field name="name">Áreas</field>
        <field name="res_model">helpdesk.team</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_team_search"/>
    </record>

</odoo>
