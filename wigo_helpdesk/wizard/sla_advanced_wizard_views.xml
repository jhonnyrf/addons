<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_sla_advanced_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.sla.advanced.wizard.form</field>
        <field name="model">helpdesk.sla.advanced.wizard</field>
        <field name="arch" type="xml">
            <form string="Configurar SLA">
                <sheet>

                    <!-- Vista previa del SLA -->
                    <div class="alert alert-secondary wigo_sla_wizard_status mb-3 py-2 px-3" role="status">
                        <div class="wigo_sla_wizard_row">
                            <div class="wigo_sla_wizard_label text-muted">Inicio:</div>
                            <div class="wigo_sla_wizard_col" invisible="not sla_start_datetime_preview">
                                <field name="sla_start_datetime_preview" nolabel="1" readonly="1"/>
                            </div>
                        </div>

                        <div class="wigo_sla_wizard_row">
                            <div class="wigo_sla_wizard_label text-muted">Límite:</div>
                            <div class="wigo_sla_wizard_col" invisible="not sla_deadline_preview">
                                <field name="sla_deadline_preview" nolabel="1" readonly="1"/>
                            </div>
                        </div>

                        <div class="wigo_sla_wizard_row">
                            <div class="wigo_sla_wizard_label text-muted">Horas restantes:</div>
                            <div class="wigo_sla_wizard_col" invisible="not sla_deadline_preview">
                                <field name="sla_hours_remaining_preview_display" nolabel="1" readonly="1"/>
                            </div>
                        </div>
                    </div>

                    <!-- Selector de modo -->
                    <group>
                        <field name="sla_mode" widget="radio" string="Tipo de configuración"/>
                    </group>

                    <!-- Modo DIAS -->
                    <group string="⏱ Duración en días" invisible="sla_mode != 'quick'">
                        <div class="text-muted small mb-2">
                            El límite SLA se calculará desde la fecha de apertura del ticket (o desde el inicio ya guardado si el SLA fue aplicado antes).
                        </div>
                        <group col="2">
                            <field name="sla_quick_days" string="Días de resolución" widget="radio"/>
                        </group>
                    </group>

                    <!-- Modo AVANZADO -->
                    <group string="📅 Fechas personalizadas" invisible="sla_mode != 'advanced'">
                        <div class="text-muted small mb-2">
                            Define exactamente cuándo empieza y termina el período SLA.
                        </div>
                        <group col="2">
                            <field name="sla_start_datetime" string="🔓 Inicio SLA"/>
                            <field name="sla_end_datetime" string="⏳ Fin SLA"/>
                        </group>
                    </group>

                </sheet>
                <footer>
                    <button name="action_apply" type="object" string="Aplicar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
