<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="wigo_ftth.FtthWorkOrderPrintConfigPreview">
        <div class="wigo-ftth-preview-shell" style="position:relative; min-height:260px;">
            <div t-ref="configHtmlContainer"/>
            <t t-if="state.loading">
