<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         ACCESORIO — Catálogo de materiales FTTH
    ═══════════════════════════════════════════════════════════════════ -->

    <record id="view_ftth_accesorio_list" model="ir.ui.view">
        <field name="name">ftth.accesorio.list</field>
        <field name="model">ftth.accesorio</field>
        <field name="arch" type="xml">
            <list string="Catálogo de accesorios" decoration-muted="not active">
                <field name="name"/>
                <field name="codigo"/>
                <field name="tipo_unidad" string="Unidad"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_ftth_accesorio_form" model="ir.ui.view">
        <field name="name">ftth.accesorio.form</field>
        <field name="model">ftth.accesorio</field>
        <field name="arch" type="xml">
            <form string="Accesorio FTTH">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nombre del accesorio"/>
                        <h1>
                            <field name="name" placeholder="Ej: Cable Drop, Conectores SC APC, Grapas..."/>
                        </h1>
                    </div>

                    <group col="2">
                        <group string="Información básica">
                            <field name="codigo" placeholder="Código SKU (opcional)"/>
                            <field name="tipo_unidad" widget="radio"/>
                        </group>
                        <group string="Estado">
                            <field name="active" widget="boolean"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Notas" name="notes">
                            <group>
                                <field name="notas" nolabel="1" placeholder="Información adicional sobre el accesorio..."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ftth_accesorio_search" model="ir.ui.view">
        <field name="name">ftth.accesorio.search</field>
        <field name="model">ftth.accesorio</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="codigo"/>
                <separator/>
                <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Metros" name="metros" domain="[('tipo_unidad', '=', 'm')]"/>
                <filter string="Unidades" name="unidades" domain="[('tipo_unidad', '=', 'unidad')]"/>
                <separator/>
                <filter string="Agrupar por tipo de unidad" name="group_tipo" context="{'group_by': 'tipo_unidad'}"/>
            </search>
        </field>
    </record>

    <record id="action_ftth_accesorio" model="ir.actions.act_window">
        <field name="name">Catálogo de accesorios</field>
        <field name="res_model">ftth.accesorio</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ftth_accesorio_search"/>
        <field name="domain">[]</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay accesorios registrados
            </p>
            <p>
                Crea un nuevo accesorio en el catálogo para utilizarlo en órdenes de trabajo e instalaciones.
            </p>
        </field>
    </record>

</odoo>
