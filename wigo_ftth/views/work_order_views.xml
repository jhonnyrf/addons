<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==========================================================================
         SEARCH VIEW
    ========================================================================== -->
    <record id="view_ftth_work_order_search" model="ir.ui.view">
        <field name="name">wigo.ftth.work.order.search</field>
        <field name="model">wigo.ftth.work.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="customer_code"/>
                <field name="regional_id"/>
                <field name="installer_id"/>

                <separator/>

                <!-- State filters -->
                <filter string="Pendientes" name="filter_pending" domain="[('state','=','pending')]"/>
                <filter string="Asignadas" name="filter_assigned" domain="[('state','=','assigned')]"/>
                <filter string="En campo" name="filter_in_field" domain="[('state','=','in_field')]"/>
                <filter string="Activas" name="filter_active" domain="[('state','=','active')]"/>
                <filter string="Con incidencia" name="filter_incident" domain="[('state','=','incident')]"/>
                <filter string="Canceladas" name="filter_cancelled" domain="[('state','=','cancelled')]"/>

                <!-- Type filters -->
                <filter string="Instalaciones" name="filter_installation" domain="[('work_type','=','installation')]"/>
                <filter string="Bajas" name="filter_deactivation" domain="[('work_type','=','deactivation')]"/>

                <separator/>

                <!-- Group By -->
                <filter string="Agrupar por estado" name="group_by_state" context="{'group_by':'state'}"/>
                <filter string="Agrupar por instalador" name="group_by_installer" context="{'group_by':'installer_id'}"/>
                <filter string="Agrupar por regional" name="group_by_regional" context="{'group_by':'regional_id'}"/>
            </search>
        </field>
    </record>

    <!-- ==========================================================================
         KANBAN VIEW
    ========================================================================== -->
    <record id="view_ftth_work_order_kanban" model="ir.ui.view">
        <field name="name">wigo.ftth.work.order.kanban</field>
        <field name="model">wigo.ftth.work.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">

                <field name="name"/>
                <field name="partner_id"/>
                <field name="customer_code"/>
                <field name="regional_id"/>
                <field name="work_type"/>
                <field name="state"/>
                <field name="installer_id"/>
                <field name="scheduled_date"/>

                <templates>
                    <t t-name="card">
                        <div class="fw-bold">
                            <field name="name" readonly="1"/>
                        </div>

                        <div class="text-muted small">
                            <i class="fa fa-user me-1" title="Cliente"/>
                            <field name="partner_id"/>
                        </div>

                        <div class="small" invisible="not regional_id">
                            <span class="badge bg-info">
                                <field name="regional_id"/>
                            </span>
                        </div>

                        <div class="small" invisible="not customer_code">
                            <span class="badge bg-secondary">
                                <field name="customer_code"/>
                            </span>
                        </div>

                        <footer class="d-flex justify-content-between align-items-center mt-2">
                            <span class="text-muted small">
                                <i class="fa fa-calendar me-1" title="Fecha"/>
                                <field name="scheduled_date"/>
                            </span>

                            <span invisible="not installer_id" class="badge bg-light text-dark">
                                <field name="installer_id"/>
                            </span>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ==========================================================================
         LIST VIEW
    ========================================================================== -->
    <record id="view_ftth_work_order_list" model="ir.ui.view">
        <field name="name">wigo.ftth.work.order.list</field>
        <field name="model">wigo.ftth.work.order</field>
        <field name="arch" type="xml">
            <list string="Órdenes de Trabajo" decoration-success="state == 'active'" decoration-warning="state in ['assigned','in_field','installed']" decoration-danger="state == 'incident'" decoration-muted="state in ['deactivation_executed','cancelled']">

                <field name="name"/>
                <field name="regional_id" optional="show"/>
                <field name="work_type" widget="badge"/>
                <field name="partner_id"/>
                <field name="customer_code"/>
                <field name="plan_id"/>
                <field name="installer_id"/>
                <field name="execution_date"/>

                <field name="state" widget="badge" decoration-muted="state in ['pending','deactivation_executed','cancelled']" decoration-warning="state == 'assigned'" decoration-info="state == 'in_field'" decoration-primary="state == 'installed'" decoration-success="state == 'active'" decoration-danger="state == 'incident'"/>
            </list>
        </field>
    </record>

    <!-- ==========================================================================
         FORM VIEW
    ========================================================================== -->
    <record id="view_ftth_work_order_form" model="ir.ui.view">
        <field name="name">wigo.ftth.work.order.form</field>
        <field name="model">wigo.ftth.work.order</field>
        <field name="arch" type="xml">
            <form string="Orden de Trabajo FTTH" readonly="state in ['active', 'cancelled']" class="wigo_ftth_work_order_form">

                <!-- HEADER -->
                <header>
                    <button name="action_assign" type="object" string="Asignar" class="btn-primary" invisible="state != 'pending'"/>

                    <button name="action_print_work_order_pdf" type="object" string="Imprimir OT" class="btn-secondary" invisible="state != 'assigned'"/>

                    <button name="action_in_field" type="object" string="Enviar a campo" class="btn-primary" invisible="state != 'assigned'"/>

                    <button name="action_installed" type="object" string="Equipo instalado" class="btn-primary" invisible="work_type == 'deactivation' or state != 'in_field'"/>

                    <button name="action_activate" type="object" string="✓ Activar cliente" class="btn-success" invisible="work_type == 'deactivation' or state != 'installed'" confirm="¿Confirmar activación? Se creará la ficha técnica del cliente."/>

                    <!-- 'Registrar incidencia' moved to Ficha Técnica (wigo.ftth.client.service) -->

                    <button name="action_execute_deactivation" type="object" string="Ejecutar baja" class="btn-danger" invisible="work_type != 'deactivation' or state != 'in_field'" confirm="¿Confirmar baja? Se liberará la subinterfaz, el puerto y la ONU."/>

                    <button name="action_cancel" type="object" string="Cancelar OT" class="btn-secondary" invisible="state in ['active','deactivation_executed','cancelled']" confirm="¿Cancelar esta orden de trabajo? Se liberarán los recursos asociados (subinterfaz, puerto de caja, ONU)."/>

                    <field name="state" widget="statusbar" statusbar_visible="pending,assigned,in_field,installed,active" invisible="work_type == 'deactivation'" readonly="state in ['active', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,assigned,in_field,deactivation_executed" invisible="work_type != 'deactivation'" readonly="state in ['deactivation_executed', 'cancelled']"/>
                </header>

                <sheet readonly="state == 'active'">

                    <!-- RIBBONS -->
                    <widget name="web_ribbon" title="Con incidencia" bg_color="text-bg-warning" invisible="state != 'incident'"/>

                    <widget name="web_ribbon" title="Baja ejecutada" bg_color="text-bg-danger" invisible="state != 'deactivation_executed'"/>

                    <widget name="web_ribbon" title="Cancelada" bg_color="text-bg-secondary" invisible="state != 'cancelled'"/>

                    <!-- ACTION BUTTON -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_client_service" type="object" class="oe_stat_button" icon="fa-id-card-o" invisible="not client_service_id">
                            <span class="o_stat_text">Ver ficha técnica</span>
                        </button>
                    </div>

                    <!-- TITLE -->
                    <div class="oe_title">
                        <label for="name" string="OT"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- SUMMARY (arriba: lectura rápida) -->
                    <group col="4">
                        <group string="OT / Cliente" colspan="2">
                            <field name="work_type" readonly="1"/>
                            <field name="contract_id" domain="[('state', '=', 'active')]" readonly="state == 'active'"/>

                            <field name="partner_id" readonly="1"/>
                            <field name="customer_code" readonly="1"/>
                            <field name="plan_id" readonly="1"/>
                        </group>

                        <group string="Planificación" colspan="2">
                            <field name="scheduled_date" readonly="1" force_save="1" invisible="work_type == 'deactivation'"/>
                            <field name="execution_date" readonly="1"/>

                            <field name="installer_id" groups="wigo_ftth.group_ftth_tech,base.group_erp_manager" readonly="state == 'active'"/>
                            <field name="technical_responsible_id" domain="[('department_id.name', '=', 'Area Técnica')]" readonly="state == 'active'"/>
                        </group>
                    </group>

                    <!-- DETAIL TABS (menos scroll, mejor separación) -->
                    <notebook>
                        <page string="Cliente">
                            <group col="4">
                                <group string="Contacto" colspan="2">
                                    <field name="address" readonly="1" force_save="1"/>
                                    <field name="contact_phone" readonly="1" force_save="1"/>
                                </group>
                                <group string="Ubicación" colspan="2">
                                    <field name="location_link" widget="url" readonly="1" force_save="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Datos técnicos" groups="wigo_ftth.group_ftth_tech,base.group_erp_manager">
                            <group col="4">
                                <group string="Selección" colspan="2">
                                    <field name="zone_id" readonly="state == 'active' or work_type == 'deactivation'"/>

                                    <field name="box_group_id" domain="[('zone_id','=',zone_id)]" readonly="not zone_id or state == 'active' or work_type == 'deactivation'" options="{'no_create': True}"/>

                                    <field name="box_id" domain="[('box_group_id','=',box_group_id)]" readonly="not box_group_id or state == 'active' or work_type == 'deactivation'" options="{'no_create': True}"/>

                                    <field name="box_port_id" domain="[('box_id','=',box_id),('state','=','occupied')]" readonly="not box_id or state == 'active' or work_type == 'deactivation'" options="{'no_create': True}"/>
                                </group>

                                <group string="Ruta calculada" colspan="2">
                                    <field name="regional_id" readonly="1" force_save="1"/>
                                    <field name="node_id" readonly="1" force_save="1"/>
                                    <field name="olt_id" readonly="1" force_save="1"/>
                                    <field name="olt_port_id" readonly="1" force_save="1"/>

                                    <field name="subinterface_id" domain="[('olt_port_id','=',olt_port_id),('state','=','occupied')]" readonly="1" force_save="1"/>

                                    <field name="odn_id" readonly="1" force_save="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Equipo ONU" groups="wigo_ftth.group_ftth_tech,base.group_erp_manager">
                            <group col="4">
                                <group string="Selección" colspan="2">
                                    <field name="onu_id"/>
                                </group>

                                <group string="Detalle" colspan="2" invisible="not onu_id">
                                    <group col="2">
                                        <field name="onu_state" readonly="1"/>
                                        <field name="onu_serial_number" readonly="1"/>
                                        <field name="onu_rotulo" readonly="1"/>
                                        <field name="onu_marca" readonly="1"/>
                                        <field name="onu_modelo" readonly="1"/>
                                        <field name="onu_perfil_olt" readonly="1"/>
                                        <field name="onu_pon_sn" readonly="1"/>
                                        <field name="onu_wifi_ssid" readonly="1"/>
                                        <field name="onu_wifi_password" readonly="1" widget="password"/>
                                    </group>
                                </group>
                            </group>
                        </page>

                        <page string="Accesorios" invisible="work_type == 'deactivation'">
                            <field name="work_order_accessories" readonly="state == 'active'">
                                <list editable="bottom">
                                    <field name="accesorio_id" domain="[('active', '=', True)]"/>
                                    <field name="cantidad"/>
                                    <field name="unidad" readonly="1"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notas">
                            <group>
                                <field name="notes" nolabel="1"/>
                            </group>
                            <group string="Cancelación" invisible="state != 'cancelled'">
                                <field name="cancellation_reason" nolabel="1" readonly="1"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>

                <!-- CHATTER -->
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>

            </form>
        </field>
    </record>

    <!-- ==========================================================================
          ACTION
     ========================================================================== -->
    <record id="action_ftth_work_order" model="ir.actions.act_window">
        <field name="name">Órdenes de Trabajo</field>
        <field name="res_model">wigo.ftth.work.order</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ftth_work_order_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay órdenes de trabajo</p>
            <p>Se crean automáticamente al ganar un lead en el CRM.</p>
        </field>
    </record>

</odoo>