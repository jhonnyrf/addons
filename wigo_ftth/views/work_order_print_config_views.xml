<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ftth_work_order_print_config_form" model="ir.ui.view">
        <field name="name">wigo.ftth.work.order.print.config.form</field>
        <field name="model">wigo.ftth.work.order.print.config</field>
        <field name="arch" type="xml">
            <form string="Configuración Planilla OT FTTH" create="false" delete="false">
                <header>
                    <button name="action_reset_defaults" string="↺ Restaurar diseño por defecto" type="object" class="btn-secondary" confirm="¿Restaurar los valores de diseño de la planilla OT?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>⚙️ Configuración de Planilla PDF OT FTTH</h1>
                    </div>

                    <group col="2" string="Encabezado">
                        <group>
                            <field name="titulo_documento"/>
                            <field name="subtitulo_documento"/>
                        </group>
                        <group>
                            <field name="usar_logo_imagen"/>
                            <field name="logo" widget="image" options="{'size': [350, 140]}"/>
                            <field name="logo_ancho"/>
                        </group>
                    </group>

                    <group col="2" string="Empresa">
                        <group>
                            <field name="empresa_nombre"/>
                            <field name="empresa_direccion"/>
                            <field name="empresa_ciudad"/>
                        </group>
                        <group>
                            <field name="empresa_telefono"/>
                            <field name="empresa_email"/>
                        </group>
                    </group>

                    <group col="2" string="Firma">
                        <group>
                            <field name="firma_nombre"/>
                        </group>
                        <group>
                            <field name="firma_cargo"/>
                        </group>
                    </group>

                    <group col="2" string="Códigos QR">
                        <group>
                            <field name="qr_cobranzas" widget="image" options="{'size': [120, 120]}"/>
                            <field name="qr_cobranzas_fname" invisible="1"/>
                        </group>
                        <group>
                            <field name="qr_soporte" widget="image" options="{'size': [120, 120]}"/>
                            <field name="qr_soporte_fname" invisible="1"/>
                        </group>
                    </group>

                    <group col="2" string="Diseño">
                        <group>
                            <field name="color_primario" widget="color"/>
                            <field name="color_secundario" widget="color"/>
                            <field name="color_texto_header" widget="color"/>
                            <field name="color_borde" widget="color"/>
                            <field name="color_fondo" widget="color"/>
                            <field name="color_texto" widget="color"/>
                        </group>
                        <group>
                            <field name="fuente_familia"/>
                            <field name="tamano_fuente_base"/>
                            <field name="tamano_titulo"/>
                            <field name="mostrar_accesorios"/>
                            <field name="mostrar_observaciones"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ftth_work_order_print_config" model="ir.actions.server">
        <field name="name">Configuración Planilla OT</field>
        <field name="model_id" ref="model_wigo_ftth_work_order_print_config"/>
        <field name="state">code</field>
        <field name="code">
config = env['wigo.ftth.work.order.print.config'].get_config()
action = {
    'type': 'ir.actions.act_window',
    'name': 'Configuración Planilla OT FTTH',
    'res_model': 'wigo.ftth.work.order.print.config',
    'view_mode': 'form',
    'res_id': config.id,
    'target': 'current',
}
        </field>
    </record>

</odoo>
