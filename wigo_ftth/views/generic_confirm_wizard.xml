<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_generic_confirm_wizard_form" model="ir.ui.view">
        <field name="name">generic.confirm.wizard.form</field>
        <field name="model">wigo.generic.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Confirmación">
                <group>
                    <field name="message" readonly="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
