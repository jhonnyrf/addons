<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ftth_installer_list" model="ir.ui.view">
        <field name="name">wigo.ftth.installer.list</field>
        <field name="model">wigo.ftth.installer</field>
        <field name="arch" type="xml">
            <list string="Instaladores" decoration-muted="state == 'inactive'">
                <field name="name"/>
                <field name="tipo" widget="badge"/>
                <field name="encargado"/>
                <field name="phone"/>
                <field name="work_order_count" string="OTs"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'active'"
                       decoration-muted="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <record id="view_ftth_installer_form" model="ir.ui.view">
        <field name="name">wigo.ftth.installer.form</field>
        <field name="model">wigo.ftth.installer</field>
        <field name="arch" type="xml">
            <form string="Instalador">
                <sheet>
                    <div class="oe_title"><h1><field name="name" placeholder="Nombre o razón social..."/></h1></div>
                    <group col="2">
                        <group>
                            <field name="tipo"/>
                            <field name="encargado" invisible="tipo != 'company'"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="work_order_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notas"><field name="notes" nolabel="1"/></group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ftth_installer" model="ir.actions.act_window">
        <field name="name">Instaladores</field>
        <field name="res_model">wigo.ftth.installer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
