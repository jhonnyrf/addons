<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ftth_installer_list" model="ir.ui.view">
        <field name="name">wigo.ftth.installer.list</field>
        <field name="model">wigo.ftth.installer</field>
        <field name="arch" type="xml">
            <list string="Instaladores" decoration-muted="state == 'inactive'">
                <field name="name"/>
                <field name="installer_type" widget="badge"/>
                <field name="manager_name"/>
                <field name="phone"/>
                <field name="work_order_count" string="OTs"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'inactive'"/>
            </list>
        </field>
    </record>

    <record id="view_ftth_installer_form" model="ir.ui.view">
        <field name="name">wigo.ftth.installer.form</field>
        <field name="model">wigo.ftth.installer</field>
        <field name="arch" type="xml">
            <form string="Instalador">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre o razón social..."/>
                        </h1>
                    </div>
                    <group col="2">
                        <group>
                            <field name="installer_type"/>
                            <field name="manager_name" invisible="installer_type != 'company'"/>
                            <field name="phone"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="work_order_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas" name="notes">
                            <group>
                                <field name="notes" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ftth_installer" model="ir.actions.act_window">
        <field name="name">Instaladores</field>
        <field name="res_model">wigo.ftth.installer</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[]</field>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aquí puedes gestionar los instaladores registrados en el sistema. Puedes crear nuevos instaladores, editar su información y consultar las órdenes de trabajo asociadas a cada uno.
            </p>
        </field>
    </record>
</odoo>
