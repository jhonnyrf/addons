<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ftth_cs_list" model="ir.ui.view">
        <field name="name">wigo.ftth.client.service.list</field>
        <field name="model">wigo.ftth.client.service</field>
        <field name="arch" type="xml">
            <list string="Fichas Técnicas de Clientes" create="false" edit="true" delete="true" decoration-success="estado_servicio == 'active'" decoration-warning="estado_servicio in ['suspended','corte']" decoration-muted="estado_servicio in ['baja','cancelado']">
                <field name="codigo_cliente"/>
                <field name="partner_id"/>
                <field name="plan_id"/>
                <field name="servicio"/>
                <field name="gestor_comercial"/>
                <field name="installer_id"/>
                <field name="fecha_instalacion"/>
                <field name="regional_id" optional="show" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <field name="nodo_id" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <field name="olt_id" string="OLT" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <field name="subinterface_id" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <field name="onu_id" string="ONU (N/S)" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <field name="estado_servicio" widget="badge" decoration-success="estado_servicio == 'active'" decoration-warning="estado_servicio == 'suspended'" decoration-danger="estado_servicio in ['corte','baja']" decoration-muted="estado_servicio == 'cancelado'"/>
            </list>
        </field>
    </record>

    <record id="view_ftth_cs_form" model="ir.ui.view">
        <field name="name">wigo.ftth.client.service.form</field>
        <field name="model">wigo.ftth.client.service</field>
        <field name="arch" type="xml">
            <form string="Ficha Técnica del Cliente">
                <header>
                    <field name="estado_servicio" widget="statusbar" statusbar_visible="active,suspended,corte,baja"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Suspendido" bg_color="text-bg-warning" invisible="estado_servicio != 'suspended'"/>
                    <widget name="web_ribbon" title="En corte" bg_color="text-bg-danger" invisible="estado_servicio != 'corte'"/>
                    <widget name="web_ribbon" title="Dado de baja" bg_color="text-bg-danger" invisible="estado_servicio != 'baja'"/>
                    <widget name="web_ribbon" title="Cancelado" bg_color="text-bg-secondary" invisible="estado_servicio != 'cancelado'"/>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_work_order" type="object" class="oe_stat_button" icon="fa-wrench" invisible="not work_order_id">
                            <span class="o_stat_text">OT origen</span>
                        </button>

                        <button name="action_sync_from_work_order" type="object" class="oe_stat_button" icon="fa-refresh" invisible="not work_order_id">
                            <span class="o_stat_text">Actualizar datos</span>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="codigo_cliente" string="Código de cliente"/>
                        <h1>
                            <field name="codigo_cliente" readonly="1"/>
                        </h1>
                    </div>

                    <!-- RESUMEN (arriba: lectura rápida, menos scroll) -->
                    <group col="4">
                        <group string="Cliente / Servicio" colspan="2">
                            <field name="partner_id" readonly="1"/>
                            <field name="plan_id" readonly="1"/>
                            <field name="servicio" readonly="1"/>
                        </group>

                        <group string="Operación" colspan="2">
                            <field name="fecha_instalacion" readonly="1"/>
                            <field name="fecha_baja" invisible="estado_servicio not in ['baja','cancelado']"/>
                            <field name="installer_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- DETALLE (pestañas) -->
                    <notebook>
                        <page string="Servicio">
                            <group col="4">
                                <group string="Comercial" colspan="2">
                                    <field name="gestor_comercial"/>
                                    <field name="responsable_comercial_id"/>
                                    <field name="metraje"/>
                                </group>

                                <group string="Ubicación" colspan="2">
                                    <field name="link_ubicacion" widget="url" readonly="1"/>
                                </group>
                            </group>

                            <group string="Origen" col="2">
                                <group>
                                    <field name="work_order_id" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Equipo ONU" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager">
                            <group col="4">
                                <group string="ONU asignada" colspan="2">
                                    <field name="onu_id" readonly="1"/>
                                </group>

                                <group string="Detalle" colspan="2" invisible="not onu_id">
                                    <group col="2">
                                        <field name="onu_state" readonly="1"/>
                                        <field name="onu_serial_number" readonly="1"/>
                                        <field name="onu_rotulo" readonly="1"/>
                                        <field name="onu_marca" readonly="1"/>
                                        <field name="onu_modelo" readonly="1"/>
                                        <field name="onu_perfil_olt" readonly="1"/>
                                        <field name="onu_pon_sn" readonly="1"/>
                                        <field name="onu_wifi_ssid" readonly="1"/>
                                        <field name="onu_wifi_password" readonly="1" widget="password"/>
                                    </group>
                                </group>
                            </group>
                        </page>

                        <page string="Topología" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager">
                            <group col="4">
                                <group string="OLT / Subinterfaz" colspan="2">
                                    <field name="regional_id" readonly="1"/>
                                    <field name="nodo_id" readonly="1"/>
                                    <field name="olt_id" readonly="1"/>
                                    <field name="olt_port_id" readonly="1"/>
                                    <field name="subinterface_id" readonly="1"/>
                                    <field name="odn_id" readonly="1"/>
                                </group>

                                <group string="NAP" colspan="2">
                                    <field name="box_group_id" readonly="1"/>
                                    <field name="box_id" readonly="1"/>
                                    <field name="box_port_id" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="Configuración" groups="wigo_ftth.group_ftth_tech,base.group_erp_manager">
                            <group col="4">
                                <group string="PPPoE / VLAN" colspan="2">
                                    <field name="pppoe_user"/>
                                    <field name="pppoe_password" password="True"/>
                                    <field name="vlan"/>
                                </group>

                                <group string="T-CONT / Puertos" colspan="2">
                                    <field name="tcont"/>
                                    <field name="gemport"/>
                                    <field name="vport"/>
                                </group>
                            </group>
                        </page>

                        <page string="WiFi" groups="wigo_ftth.group_ftth_tech,base.group_erp_manager">
                            <group col="2">
                                <group>
                                    <field name="wifi_ssid"/>
                                    <field name="wifi_pass" password="True"/>
                                </group>
                            </group>
                        </page>

                        <page string="Equipos adicionales" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager">

                            <field name="additional_equipment_ids" context="{'default_state': 'assigned'}">
                                <list create="true" edit="false" delete="true">
                                    <field name="name"/>
                                    <field name="marca"/>
                                    <field name="rotulo"/>
                                    <field name="serial_number" string="S/N"/>
                                    <field name="state" widget="badge"/>
                                    <field name="notes" optional="hide"/>
                                </list>
                            </field>

                        </page>

                        <page string="Observaciones" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager">
                            <group>
                                <field name="observaciones" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_ftth_cs_search" model="ir.ui.view">
        <field name="name">wigo.ftth.client.service.search</field>
        <field name="model">wigo.ftth.client.service</field>
        <field name="arch" type="xml">
            <search>
                <field name="codigo_cliente"/>
                <field name="partner_id"/>
                <field name="gestor_comercial"/>
                <field name="nodo_id"/>
                <separator/>
                <filter string="Activos" name="active" domain="[('estado_servicio','=','active')]"/>
                <filter string="Suspendidos" name="suspended" domain="[('estado_servicio','=','suspended')]"/>
                <filter string="En corte" name="corte" domain="[('estado_servicio','=','corte')]"/>
                <filter string="Dados de baja" name="baja" domain="[('estado_servicio','=','baja')]"/>
                <filter string="Cancelados" name="cancelado" domain="[('estado_servicio','=','cancelado')]"/>
                <separator/>
                <filter string="Por estado" name="group_estado" context="{'group_by':'estado_servicio'}"/>
                <filter string="Por plan" name="group_plan" context="{'group_by':'plan_id'}"/>
                <filter string="Por instalador" name="group_instalador" context="{'group_by':'installer_id'}"/>
                <filter string="Por gestor" name="group_gestor" context="{'group_by':'gestor_comercial'}"/>
                <filter string="Por mes inst." name="group_mes" context="{'group_by':'fecha_instalacion:month'}"/>
                <filter string="Por regional" name="group_regional" context="{'group_by':'regional_id'}" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <filter string="Por nodo" name="group_nodo" context="{'group_by':'nodo_id'}" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
                <filter string="Por OLT" name="group_olt" context="{'group_by':'olt_id'}" groups="wigo_ftth.group_ftth_tech,wigo_ftth.group_ftth_readonly,base.group_erp_manager"/>
            </search>
        </field>
    </record>

    <record id="action_ftth_client_service" model="ir.actions.act_window">
        <field name="name">Fichas Técnicas de Clientes</field>
        <field name="res_model">wigo.ftth.client.service</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ftth_cs_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay fichas técnicas aún</p>
            <p>Se crean automáticamente al activar una Orden de Trabajo.</p>
        </field>
    </record>

</odoo>
