<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cancel_work_order_wizard_form" model="ir.ui.view">
        <field name="name">wigo.ftth.cancel.work.order.wizard.form</field>
        <field name="model">wigo.ftth.cancel.work.order.wizard</field>
        <field name="arch" type="xml">
            <form string="Cancelar Orden de Trabajo">
                <group>
                    <field name="work_order_id" invisible="1"/>
                    <field name="cancellation_reason" placeholder="Indique el motivo de la cancelación…"/>
                </group>
                <footer>
                    <button name="action_confirm_cancel" type="object" string="Confirmar cancelación" class="btn-danger"/>
                    <button string="Volver" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
