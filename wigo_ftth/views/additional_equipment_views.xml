<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ftth_additional_equipment_list" model="ir.ui.view">
        <field name="name">wigo.ftth.additional.equipment.list</field>
        <field name="model">wigo.ftth.additional.equipment</field>
        <field name="arch" type="xml">
            <list string="Equipos Adicionales">
                <field name="name"/>
                <field name="marca"/>
                <field name="rotulo"/>
                <field name="serial_number" string="S/N"/>
                <field name="client_service_id" string="Servicio asignado"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_ftth_additional_equipment_form" model="ir.ui.view">
        <field name="name">wigo.ftth.additional.equipment.form</field>
        <field name="model">wigo.ftth.additional.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipo adicional">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nombre del equipo..."/>
                        </h1>
                    </div>
                    <group col="2">
                        <group>

                            <field name="rotulo"/>
                            <field name="serial_number" string="S/N"/>
                            <field name="client_service_id"/>
                        </group>
                        <group>
                            <field name="marca"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notas" name="notes">
                            <group>
                                <field name="notes" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_ftth_additional_equipment_search" model="ir.ui.view">
        <field name="name">wigo.ftth.additional.equipment.search</field>
        <field name="model">wigo.ftth.additional.equipment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="marca"/>
                <field name="rotulo"/>
                <field name="serial_number"/>
                <separator/>
                <filter string="Disponibles" name="available" domain="[('state','=','available')]"/>
                <filter string="Asignados" name="assigned" domain="[('state','=','assigned')]"/>
                <separator/>
                <filter string="Agrupar por servicio" name="by_client_service" context="{'group_by':'client_service_id'}"/>
                <filter string="Agrupar por estado" name="by_state" context="{'group_by':'state'}"/>
            </search>
        </field>
    </record>

    <record id="action_ftth_additional_equipment" model="ir.actions.act_window">
        <field name="name">Equipos Adicionales</field>
        <field name="res_model">wigo.ftth.additional.equipment</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_ftth_additional_equipment_search"/>
    </record>
</odoo>
