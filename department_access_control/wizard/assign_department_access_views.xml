<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wizard_assign_department_access_form" model="ir.ui.view">
        <field name="name">wizard.assign.department.access.form</field>
        <field name="model">wizard.assign.department.access</field>
        <field name="arch" type="xml">
            <form string="Asignar Permisos de Departamento">
                <sheet>
                    <group string="Configuración">
                        <field name="department_id"/>
                        <field name="apply_to" widget="radio"/>
                        <field name="employee_ids"
                               widget="many2many_tags"
                               invisible="apply_to != 'selected_employees'"
                               domain="[('department_id', '=', department_id)]"/>
                        <field name="action_type" widget="radio"/>
                    </group>

                    <group string="Resumen">
                        <div class="alert alert-info" role="alert">
                            <field name="employee_count" readonly="1"/>
                            empleado(s) serán afectados por esta acción.
                            <div invisible="not department_has_restrictions"
                                 class="mt-2">
                                <i class="fa fa-info-circle"/> Este departamento tiene restricciones de acceso configuradas.
                            </div>
                        </div>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply"
                            type="object"
                            string="Aplicar"
                            class="btn-primary"/>
                    <button string="Cancelar"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_assign_department_access" model="ir.actions.act_window">
        <field name="name">Asignar Permisos de Departamento</field>
        <field name="res_model">wizard.assign.department.access</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
