<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción para ver todos los departamentos con su configuración de acceso -->
    <record id="action_dept_access_config" model="ir.actions.act_window">
        <field name="name">Configuración de Acceso por Departamento</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sin departamentos configurados todavía.
            </p>
            <p>
                Crea departamentos y activa sus restricciones de acceso para controlar
                qué puede ver y hacer cada área en Odoo.
            </p>
        </field>
    </record>

    <!-- Acción para ver permisos individuales de empleados -->
    <record id="action_employee_module_access" model="ir.actions.act_window">
        <field name="name">Permisos Individuales de Empleados</field>
        <field name="res_model">department.employee.module.access</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Sin permisos individuales configurados.
            </p>
            <p>
                Configura permisos especiales para empleados que necesiten acceso
                diferente al de su departamento.
            </p>
        </field>
    </record>

    <!-- Menú principal bajo "Empleados" -->
    <menuitem
        id="menu_dept_access_root"
        name="Control de Acceso"
        parent="hr.menu_hr_root"
        sequence="99"
        groups="department_access_control.group_department_access_manager"/>

    <menuitem
        id="menu_dept_access_config"
        name="Acceso por Departamento"
        parent="menu_dept_access_root"
        action="action_dept_access_config"
        sequence="10"/>

    <menuitem
        id="menu_employee_individual_access"
        name="Permisos Individuales"
        parent="menu_dept_access_root"
        action="action_employee_module_access"
        sequence="20"/>

    <menuitem
        id="menu_all_access_rules"
        name="Reglas de Acceso a Datos"
        parent="menu_dept_access_root"
        action="action_all_access_rules"
        sequence="30"/>

    <menuitem
        id="menu_dept_access_wizard"
        name="Aplicar Permisos en Masa"
        parent="menu_dept_access_root"
        action="department_access_control.action_wizard_assign_department_access"
        sequence="40"/>

</odoo>
