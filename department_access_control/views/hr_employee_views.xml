<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Hereda la vista del Empleado -->
    <record id="view_hr_employee_form_access" model="ir.ui.view">
        <field name="name">hr.employee.form.access</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <!-- Botón estadístico en el encabezado -->
            <div name="button_box" position="inside">
                <button name="action_view_individual_module_access"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-key"
                        groups="department_access_control.group_department_access_manager">
                    <field name="individual_module_count" widget="statinfo"
                           string="Módulos Ind."/>
                </button>
            </div>

            <!-- Pestaña de Permisos individuales del Empleado -->
            <page name="resume" position="after">
                <page name="employee_access"
                      string="Permisos de Acceso"
                      groups="department_access_control.group_department_access_manager">

                    <group string="Configuración de Acceso">
                        <field name="use_department_access"/>
                    </group>

                    <!-- Resumen de acceso efectivo -->
                    <group string="Resumen de Acceso Efectivo">
                        <field name="access_summary"
                               nolabel="1"
                               readonly="1"
                               widget="text"
                               style="font-family: monospace; font-size: 0.85rem;"/>
                    </group>

                    <!-- Permisos individuales de módulos -->
                    <separator string="Permisos Individuales de Módulos"/>
                    <p class="text-muted small">
                        Estos permisos son específicos para este empleado y sobreescriben
                        la configuración de su departamento cuando "Sobreescribe al Departamento" está activo.
                    </p>
                    <field name="individual_module_access_ids" nolabel="1">
                        <list editable="bottom" string="Permisos por Módulo">
                            <field name="menu_id"
                                   string="Módulo / Menú / Sección"
                                   context="{'tree_view_ref': 'department_access_control.view_ir_ui_menu_tree_department_access'}"/>
                            <field name="menu_name" string="Nombre" optional="show" readonly="1"/>
                            <field name="include_children"
                                string="Incluir Submenús"
                                widget="boolean_toggle"/>
                            <field name="access_type"
                                   string="Acceso"
                                   widget="badge"
                                   decoration-success="access_type == 'visible'"
                                   decoration-danger="access_type == 'hidden'"/>
                            <field name="override_department"
                                   string="Sobreescribe Dpto."
                                   widget="boolean_toggle"/>
                            <field name="active"
                                   string="Activo"
                                   widget="boolean_toggle"/>
                            <field name="reason" string="Razón" optional="show"/>
                        </list>
                    </field>

                </page>
            </page>

        </field>
    </record>

</odoo>
