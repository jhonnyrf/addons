<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_department_access" model="ir.module.category">
        <field name="name">Control de Acceso por Departamento</field>
        <field name="description">Gestión de permisos y acceso por departamento</field>
        <field name="sequence">25</field>
    </record>

    <record id="privilege_department_access" model="res.groups.privilege">
        <field name="name">Control de Acceso por Departamento</field>
        <field name="description">Permisos del módulo de control de acceso por departamento</field>
        <field name="sequence">25</field>
        <field name="category_id" ref="module_category_department_access"/>
    </record>

    <!-- Administrador: puede configurar todo -->
    <record id="group_department_access_manager" model="res.groups">
        <field name="name">Administrador de Acceso por Departamento</field>
        <field name="privilege_id" ref="privilege_department_access"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
